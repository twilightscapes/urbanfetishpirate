  function playInTopPlayer(videoId, title, channelName, thumbnail) {
    const player = document.getElementById('yt-top-player');
    if (!player) return;
    player.dataset.ytId = videoId;
    playYTVideo(player, videoId);

    // Update now-playing info
    const nowPlaying = document.getElementById('yt-now-playing');
    const nowTitle = document.getElementById('yt-now-title');
    const nowChannel = document.getElementById('yt-now-channel');
    if (nowPlaying) {
      nowPlaying.classList.remove('hidden');
      nowTitle.textContent = title || '';
      nowChannel.textContent = channelName || '';
    }
    // Update heart state
    const nowHeart = document.getElementById('yt-now-heart');
    if (nowHeart) {
      nowHeart.dataset.vidId = videoId;
      nowHeart.dataset.vidTitle = title || '';
      nowHeart.dataset.vidThumb = thumbnail || `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
      updateNowPlayingHeart(videoId);
    }
    // Scroll player into view
    player.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function playHlsInTopPlayer(hlsUrl, title, poster) {
    const player = document.getElementById('yt-top-player');
    if (!player) return;
    // Hide YouTube wrapper if it was active
    hideYTWrapper();
    if (ytActiveContainer === player) { ytActiveContainer = null; window.__ytActiveContainer = null; }
    // Create HLS video in top player
    player.innerHTML = `<video id="yt-top-hls-video" controls autoplay class="w-full h-full" poster="${escapeHtml(poster || '')}"></video>`;
    const video = document.getElementById('yt-top-hls-video');
    if (video) {
      if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = hlsUrl;
      } else if (typeof Hls !== 'undefined' && Hls.isSupported()) {
        const hls = new Hls();
        hls.loadSource(hlsUrl);
        hls.attachMedia(video);
      }
    }
    // Update now-playing bar
    const nowPlaying = document.getElementById('yt-now-playing');
    const nowTitle = document.getElementById('yt-now-title');
    const nowChannel = document.getElementById('yt-now-channel');
    if (nowPlaying) {
      nowPlaying.classList.remove('hidden');
      nowTitle.textContent = title || 'Bluesky Video';
      nowChannel.textContent = 'Bluesky';
    }
    const nowHeart = document.getElementById('yt-now-heart');
    if (nowHeart) {
      nowHeart.dataset.vidId = hlsUrl;
      nowHeart.dataset.vidTitle = title || 'Bluesky Video';
      nowHeart.dataset.vidThumb = poster || '';
      updateNowPlayingHeart(hlsUrl);
    }
    player.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function updateNowPlayingHeart(videoId) {
    const nowHeart = document.getElementById('yt-now-heart');
    if (!nowHeart) return;
    const inList = isInWatchlist(videoId);
    nowHeart.querySelector('svg').setAttribute('fill', inList ? 'currentColor' : 'none');
    nowHeart.classList.toggle('text-red-500', inList);
    nowHeart.classList.toggle('text-white', !inList);
  }

