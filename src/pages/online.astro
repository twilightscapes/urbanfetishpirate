        }
      });
    });
  }

  async function subscribeChannel(q) {
    const btn = document.getElementById('yt-add-btn');
    btn.textContent = 'Resolving...';
    btn.disabled = true;
    try {
      const res = await fetchWithTimeout(`${hubUrl}/api/youtube/resolve?q=${encodeURIComponent(q)}`);
      if (!res.ok) throw new Error('Channel not found');
      const { channelId, name } = await res.json();

      const subRes = await fetchWithTimeout(`${hubUrl}/api/youtube/channels`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({ channelId, name })
      });
      if (subRes.ok) {
        const listRes = await fetchWithTimeout(`${hubUrl}/api/youtube/channels`, {
          headers: { Authorization: `Bearer ${token}` }
        });
        if (listRes.ok) {
          youtubeChannels = await listRes.json();
          document.getElementById('yt-search').value = '';
          renderYouTubeChannels();
          
          // Show success toast
          const toast = document.createElement('div');
          toast.className = 'fixed bottom-4 right-4 bg-green-500/90 text-white px-4 py-2 rounded text-sm z-50';
          toast.textContent = `✓ Subscribed to ${name}`;
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 3000);
        }
      } else {
        const e = await subRes.json();
        alert(e.error || 'Failed to subscribe');
      }
    } catch (err) {
      alert('Failed: ' + err.message);
    } finally {
      btn.textContent = '+ Subscribe';
      btn.disabled = false;
    }
  }

  // ============================================================
  // POSTS TAB — User's own Bluesky profile
  // ============================================================
  let postsTabCursor = null;

  async function loadPostsTab(append = false) {
    hasMore = false;
    scrollSentinel.classList.add('hidden');

    if (!append) {
      feedContainer.innerHTML = SPINNER;
      // Reset in-memory session so we re-read from localStorage/hub (catches account switches)
      bskySession = null;
    }

    try {
      const session = await ensureBskySession();
      if (!session?.handle) {
        feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">Connect your Bluesky account in Settings to view your profile</div>`;
        return;
      }

      const profile = await fetchBskyProfile(session.handle);
      const feedData = await fetchBskyAuthorFeed(session.handle, append ? postsTabCursor : null);
      postsTabCursor = feedData.cursor || null;
      hasMore = !!postsTabCursor;
      const posts = (feedData.feed || []).map(item => normalizeBskyPost(item));

      if (append) {
        feedContainer.insertAdjacentHTML('beforeend', posts.map(p => renderPostCard(p)).join(''));
      } else {
        const profileHtml = `
          <div class="rounded-lg border border-theme-card-border bg-theme-card overflow-hidden mb-6">
            ${profile.banner ? `<div class="w-full h-32 md:h-48"><img src="${escapeHtml(profile.banner)}" class="w-full h-full object-cover" /></div>` : '<div class="w-full h-24 bg-theme-surface"></div>'}
            <div class="px-4 pb-4">
              <div class="flex items-end gap-4 -mt-10 mb-3">
                ${profile.avatar ? `<img src="${escapeHtml(profile.avatar)}" class="h-20 w-20 rounded-full border-4 border-theme-card" />` : '<div class="h-20 w-20 rounded-full bg-theme-surface-hover border-4 border-theme-card"></div>'}
                <div class="flex-1 min-w-0 pt-12">
                  <h2 class="font-bold text-lg">${escapeHtml(profile.displayName || profile.handle)}</h2>
                  <p class="text-sm text-theme-faint">@${escapeHtml(profile.handle)}</p>
                </div>
              </div>
              ${profile.description ? `<p class="text-sm text-theme-muted mb-3 whitespace-pre-wrap">${formatText(profile.description)}</p>` : ''}
              <div class="flex gap-6 text-sm">
                <span><strong>${profile.followersCount || 0}</strong> <span class="text-theme-faint">followers</span></span>
                <span><strong>${profile.followsCount || 0}</strong> <span class="text-theme-faint">following</span></span>
                <span><strong>${profile.postsCount || 0}</strong> <span class="text-theme-faint">posts</span></span>
              </div>
            </div>
          </div>`;
        const postsHtml = posts.map(p => renderPostCard(p)).join('');
        feedContainer.innerHTML = profileHtml + `<div class="space-y-6">${postsHtml || '<div class="text-center py-8 text-theme-faint">No posts yet</div>'}</div>`;
      }
      attachAllListeners();
      initHlsVideos();
    } catch (err) {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">Failed to load profile: ${escapeHtml(err.message)}</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  // ============================================================
  // RSS TAB — Full feed management
  // ============================================================
  let rssCurrentView = 'feeds';
  let rssCurrentFeedId = null;
  let rssCurrentPage = 1;

  async function loadRSSTab() {
    hasMore = false;
    scrollSentinel.classList.add('hidden');

    if (!token) {
      feedContainer.innerHTML = onlineMode
        ? `<div class="rounded-lg border border-theme-border bg-theme-surface p-6 text-center max-w-md mx-auto mt-8"><h2 class="text-lg font-semibold mb-2">RSS Feeds</h2><p class="text-sm text-theme-muted mb-4">RSS subscription management requires a PirateSocial node. Install your own to subscribe to RSS feeds and have them appear alongside your Bluesky timeline.</p><a href="/" class="rounded bg-theme-primary text-white px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">Get a PirateSocial Site →</a></div>`
        : '<div class="text-center py-8 text-theme-faint">Sign in to manage your RSS subscriptions</div>';
      return;
    }

    feedContainer.innerHTML = `
      <div class="space-y-4">
        <div class="rounded-lg border border-theme-card-border bg-theme-card p-4">
          <h2 class="text-lg font-semibold mb-3">${FL.heading || 'External RSS Feeds'}</h2>
          <form id="rss-add-form" class="flex gap-2 mb-3">
            <input type="text" id="rss-url-input" placeholder="https://example.com/feed.xml or @handle.bsky.social" required
              class="flex-1 rounded bg-theme-input-bg border border-theme-input-border px-2 py-1.5 text-sm focus:outline-none focus:border-theme-primary" />
            <button type="submit" id="rss-add-btn" class="rounded bg-theme-primary px-3 py-1.5 text-sm font-medium text-white hover:bg-theme-primary-hover transition whitespace-nowrap">
              ${FL.addFeed || 'Add Feed'}
            </button>
          </form>
          <div id="rss-add-error" class="hidden text-red-400 text-sm mb-2"></div>
          <div class="flex gap-2">
            <button id="rss-view-feeds" class="rounded bg-theme-surface-hover px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm transition">
              ${FL.tabMyFeeds || 'My Feeds'}
            </button>
            <button id="rss-view-posts" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
              ${FL.tabAllPosts || 'All Posts'}
            </button>
          </div>
        </div>
        <div id="rss-feeds-list" class="space-y-3"></div>
        <div id="rss-posts-list" class="hidden space-y-4"></div>
        <div id="rss-feed-detail" class="hidden">
          <button id="rss-back-to-feeds" class="text-sm text-theme-muted hover:text-theme-text mb-4 flex items-center gap-1 transition">${FL.backToFeeds || '← Back to feeds'}</button>
          <div id="rss-feed-detail-header" class="mb-6"></div>
          <div id="rss-feed-detail-posts" class="space-y-4"></div>
        </div>
        <div id="rss-loading" class="text-center py-8 text-theme-faint hidden">${L.loading || 'Loading...'}</div>
        <div id="rss-empty" class="text-center py-8 text-theme-faint hidden">${FL.noFeeds || 'No feeds yet. Add one above!'}</div>
        <div id="rss-load-more" class="mt-8 text-center hidden">
          <button id="rss-load-more-btn" class="rounded bg-theme-input-bg px-6 py-2 text-sm hover:bg-theme-surface-hover transition">${FL.loadMore || 'Load More'}</button>
        </div>
      </div>`;

    // Wire up RSS tab events
    document.getElementById('rss-view-feeds').addEventListener('click', () => rssSwitch('feeds'));
    document.getElementById('rss-view-posts').addEventListener('click', () => rssSwitch('posts'));
    document.getElementById('rss-back-to-feeds').addEventListener('click', () => rssSwitch('feeds'));
    document.getElementById('rss-load-more-btn').addEventListener('click', () => {
      rssCurrentPage++;
      if (rssCurrentView === 'posts') rssLoadAllPosts(true);
      if (rssCurrentView === 'detail') rssLoadFeedDetail(rssCurrentFeedId, true);
    });

    document.getElementById('rss-add-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = document.getElementById('rss-url-input');
      const errorEl = document.getElementById('rss-add-error');
      const btn = document.getElementById('rss-add-btn');
      let feedUrl = input.value.trim();
      // Resolve Bluesky handles to RSS
      const stripped = feedUrl.replace(/^@/, '');
      if (/^[\w.-]+\.\w{2,}$/.test(stripped) && !stripped.includes('/')) feedUrl = `https://bsky.app/profile/${stripped}/rss`;

      errorEl.classList.add('hidden');
      btn.disabled = true;
      btn.textContent = FL.adding || 'Adding...';
      try {
        const res = await fetch(`${hubUrl}/api/external-feeds`, {
          method: 'POST',
          headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ feedUrl }),
        });
        const data = await res.json();
        if (!res.ok) { errorEl.textContent = data.error || 'Failed to add feed'; errorEl.classList.remove('hidden'); return; }
        input.value = '';
        rssLoadFeeds();
      } catch { errorEl.textContent = 'Network error'; errorEl.classList.remove('hidden'); }
      finally { btn.disabled = false; btn.textContent = FL.addFeed || 'Add Feed'; }
    });

    rssCurrentView = 'feeds';
    rssCurrentPage = 1;
    rssLoadFeeds();
  }

  function rssSwitch(view) {
    rssCurrentView = view;
    rssCurrentPage = 1;
    document.getElementById('rss-feeds-list').classList.toggle('hidden', view !== 'feeds');
    document.getElementById('rss-posts-list').classList.toggle('hidden', view !== 'posts');
    document.getElementById('rss-feed-detail').classList.toggle('hidden', view !== 'detail');
    document.getElementById('rss-load-more').classList.add('hidden');
    document.getElementById('rss-view-feeds').classList.toggle('bg-theme-surface-hover', view === 'feeds');
    document.getElementById('rss-view-feeds').classList.toggle('bg-theme-input-bg', view !== 'feeds');
    document.getElementById('rss-view-posts').classList.toggle('bg-theme-surface-hover', view === 'posts');
    document.getElementById('rss-view-posts').classList.toggle('bg-theme-input-bg', view !== 'posts');
    if (view === 'feeds') rssLoadFeeds();
    if (view === 'posts') rssLoadAllPosts();
  }

  async function rssLoadFeeds() {
    const container = document.getElementById('rss-feeds-list');
    const loading = document.getElementById('rss-loading');
    const empty = document.getElementById('rss-empty');
    loading.classList.remove('hidden');
    empty.classList.add('hidden');
    container.innerHTML = '';
    try {
      const res = await fetch(`${hubUrl}/api/external-feeds`, { headers: { Authorization: `Bearer ${token}` } });
      const data = await res.json();
      const feeds = data.feeds || [];
      loading.classList.add('hidden');
      if (!feeds.length) { empty.classList.remove('hidden'); return; }
      container.innerHTML = feeds.map(feed => `
        <div class="rounded-lg border border-theme-card-border bg-theme-card p-4">
          <div class="flex items-start gap-3">
            ${feed.iconUrl
              ? `<img src="${escapeHtml(feed.iconUrl)}" class="h-8 w-8 rounded mt-0.5" onerror="this.style.display='none'" />`
              : `<div class="h-8 w-8 rounded bg-theme-surface-hover flex items-center justify-center text-theme-muted text-xs mt-0.5">RSS</div>`}
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <h3 class="font-medium text-sm truncate">${escapeHtml(feed.title || feed.feedUrl)}</h3>
                ${feed.active
                  ? '<span class="text-xs px-1.5 py-0.5 rounded-full bg-green-900 text-green-300">Active</span>'
                  : '<span class="text-xs px-1.5 py-0.5 rounded-full bg-theme-surface-hover text-theme-muted">Paused</span>'}
              </div>
              ${feed.siteUrl ? `<a href="${escapeHtml(feed.siteUrl)}" target="_blank" class="text-xs text-theme-faint hover:text-theme-text truncate block">${escapeHtml(feed.siteUrl)}</a>` : ''}
              <div class="text-xs text-theme-faint mt-1">
                ${feed._count?.posts || 0} posts
                ${feed.lastFetched ? ` · Updated ${timeAgo(feed.lastFetched)}` : ''}
                ${feed.errorCount > 0 ? ` · <span class="text-yellow-400">${feed.errorCount} errors</span>` : ''}
              </div>
              <div class="flex items-center gap-2 mt-2">
                <label class="text-xs text-theme-faint">Max posts:</label>
                <select class="rss-max-posts rounded bg-theme-surface border border-theme-border px-2 py-0.5 text-xs" data-feed-id="${feed.id}">
                  ${[5, 10, 20, 50, 100].map(n => `<option value="${n}" ${(feed.maxPosts || 20) === n ? 'selected' : ''}>${n}</option>`).join('')}
                </select>
              </div>
            </div>
            <div class="flex gap-1.5 shrink-0">
              <button class="rss-view-btn rounded bg-theme-surface-hover px-2.5 py-1 text-xs hover:bg-theme-primary transition" data-feed-id="${feed.id}" title="View posts">View</button>
              <button class="rss-refresh-btn rounded bg-theme-surface-hover px-2.5 py-1 text-xs hover:bg-theme-primary transition" data-feed-id="${feed.id}" title="Refresh">↻</button>
              <button class="rss-toggle-btn rounded px-2.5 py-1 text-xs transition ${feed.active ? 'bg-yellow-800 hover:bg-yellow-700' : 'bg-green-800 hover:bg-green-700'}" data-feed-id="${feed.id}" data-active="${feed.active}" title="${feed.active ? 'Pause' : 'Resume'}">${feed.active ? '⏸' : '▶'}</button>
              <button class="rss-delete-btn rounded bg-red-900 px-2.5 py-1 text-xs hover:bg-red-800 transition" data-feed-id="${feed.id}" title="Remove">✕</button>
            </div>
          </div>
        </div>
      `).join('');
      rssAttachFeedListeners();
    } catch {
      loading.classList.add('hidden');
      container.innerHTML = '<div class="text-center py-8 text-red-400">Failed to load feeds</div>';
    }
  }

  function rssAttachFeedListeners() {
    document.querySelectorAll('.rss-view-btn').forEach(btn => {
      btn.addEventListener('click', () => { rssCurrentFeedId = btn.dataset.feedId; rssCurrentPage = 1; rssSwitch('detail'); rssLoadFeedDetail(rssCurrentFeedId); });
    });
    document.querySelectorAll('.rss-refresh-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        btn.textContent = '...'; btn.disabled = true;
        try {
          const res = await fetch(`${hubUrl}/api/external-feeds/${btn.dataset.feedId}/refresh`, { method: 'POST', headers: { Authorization: `Bearer ${token}` } });
          const data = await res.json();
          btn.textContent = `+${data.newPosts}`;
          setTimeout(() => { btn.textContent = '↻'; btn.disabled = false; rssLoadFeeds(); }, 1500);
        } catch { btn.textContent = '!'; setTimeout(() => { btn.textContent = '↻'; btn.disabled = false; }, 1500); }
      });
    });
    document.querySelectorAll('.rss-toggle-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const active = btn.dataset.active === 'true';
        await fetch(`${hubUrl}/api/external-feeds/${btn.dataset.feedId}`, { method: 'PATCH', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' }, body: JSON.stringify({ active: !active }) });
        rssLoadFeeds();
      });
    });
    document.querySelectorAll('.rss-delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Remove this feed and all its posts?')) return;
        await fetch(`${hubUrl}/api/external-feeds/${btn.dataset.feedId}`, { method: 'DELETE', headers: { Authorization: `Bearer ${token}` } });
        rssLoadFeeds();
      });
    });
    document.querySelectorAll('.rss-max-posts').forEach(sel => {
      sel.addEventListener('change', async () => {
        await fetch(`${hubUrl}/api/external-feeds/${sel.dataset.feedId}`, { method: 'PATCH', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' }, body: JSON.stringify({ maxPosts: parseInt(sel.value, 10) }) });
        rssLoadFeeds();
      });
    });
  }

  async function rssLoadAllPosts(append) {
    const container = document.getElementById('rss-posts-list');
    const loading = document.getElementById('rss-loading');
    if (!append) { loading.classList.remove('hidden'); container.innerHTML = ''; }
    try {
      const res = await fetch(`${hubUrl}/api/timeline?source=external&page=${rssCurrentPage}`, { headers: { Authorization: `Bearer ${token}` } });
      const data = await res.json();
      loading.classList.add('hidden');
      const html = (data.posts || []).map(p => renderPostCard(normalizePiratePost(p))).join('');
      if (append) container.insertAdjacentHTML('beforeend', html);
      else container.innerHTML = html || `<div class="text-center py-8 text-theme-faint">${FL.noFeeds || 'No posts'}</div>`;
      document.getElementById('rss-load-more').classList.toggle('hidden', !data.hasMore);
      attachAllListeners();
    } catch { loading.classList.add('hidden'); container.innerHTML = '<div class="text-center py-8 text-red-400">Failed to load posts</div>'; }
  }

  async function rssLoadFeedDetail(feedId, append) {
    const header = document.getElementById('rss-feed-detail-header');
    const container = document.getElementById('rss-feed-detail-posts');
    const loading = document.getElementById('rss-loading');
    if (!append) { loading.classList.remove('hidden'); container.innerHTML = ''; }
    try {
      const res = await fetch(`${hubUrl}/api/external-feeds/${feedId}/posts?page=${rssCurrentPage}`, { headers: { Authorization: `Bearer ${token}` } });
      const data = await res.json();
      loading.classList.add('hidden');
      if (!append && data.feed) {
        header.innerHTML = `
          <div class="flex items-center gap-3">
            ${data.feed.iconUrl ? `<img src="${escapeHtml(data.feed.iconUrl)}" class="h-10 w-10 rounded" onerror="this.style.display='none'" />` : ''}
            <div>
              <h2 class="text-lg font-semibold">${escapeHtml(data.feed.title || data.feed.feedUrl)}</h2>
              ${data.feed.siteUrl ? `<a href="${escapeHtml(data.feed.siteUrl)}" target="_blank" class="text-sm text-theme-muted hover:text-theme-text">${escapeHtml(data.feed.siteUrl)}</a>` : ''}
            </div>
            <span class="text-sm text-theme-faint ml-auto">${data.total} posts</span>
          </div>`;
      }
      const html = (data.posts || []).map(p => renderPostCard(normalizePiratePost(p))).join('');
      if (append) container.insertAdjacentHTML('beforeend', html);
      else container.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No posts</div>`;
      document.getElementById('rss-load-more').classList.toggle('hidden', !data.hasMore);
      attachAllListeners();
    } catch { loading.classList.add('hidden'); container.innerHTML = '<div class="text-center py-8 text-red-400">Failed to load posts</div>'; }
  }

  // ============================================================
  // NOTIFICATIONS TAB
  // ============================================================

  function renderNotificationItem(n) {
    const a = n.author;
    const avatar = a.avatar ? `<img src="${escapeHtml(a.avatar)}" alt="" class="w-10 h-10 rounded-full object-cover flex-shrink-0" loading="lazy" />` : `<div class="w-10 h-10 rounded-full bg-theme-surface flex-shrink-0 flex items-center justify-center text-theme-faint text-sm">👤</div>`;

    const reasonIcons = {
      like: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" class="text-red-500"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`,
      repost: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-500"><polyline points="17 2 21 6 17 10"></polyline><path d="M3 11v-1a4 4 0 0 1 4-4h14"></path><polyline points="7 22 3 18 7 14"></polyline><path d="M21 13v1a4 4 0 0 1-4 4H3"></path></svg>`,
      follow: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-500"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>`,
      mention: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-500"><circle cx="12" cy="12" r="4"></circle><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"></path></svg>`,
      reply: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-sky-500"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>`,
      quote: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-orange-500"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path><path d="M8 9h2m4 0h2M8 13h8"></path></svg>`,
      starterpack_joined: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-yellow-500"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`,
    };

    const reasonLabels = {
      like: 'liked your post',
      repost: 'reposted your post',
      follow: 'followed you',
      mention: 'mentioned you',
      reply: 'replied to your post',
      quote: 'quoted your post',
      starterpack_joined: 'joined your starter pack',
      'subscribed-post': 'posted',
      'like-via-repost': 'liked your repost',
      'repost-via-repost': 'reposted your repost',
    };

    const icon = reasonIcons[n.reason] || reasonIcons.mention;
    const label = reasonLabels[n.reason] || n.reason;
    const time = timeAgo(n.indexedAt);
    const recordText = n.record?.text ? `<p class="text-sm text-theme-text whitespace-pre-wrap mt-1">${formatText(n.record.text)}</p>` : '';
    const unreadDot = n.isRead ? '' : '<span class="w-2 h-2 rounded-full bg-blue-500 flex-shrink-0"></span>';

    // Render embeds from the notification's own post
    let notifEmbedHtml = '';
    if (n.embed) {
      const embedData = extractEmbedData(n.embed);
      if (Object.keys(embedData).length) {
        notifEmbedHtml = renderEmbeds(embedData);
      }
    }

    // For likes/reposts: show the subject post (the post that was liked/reposted)
    let subjectHtml = '';
    if (n.subjectPost) {
      const sp = n.subjectPost;
      const spText = sp.text ? `<p class="text-sm text-theme-text whitespace-pre-wrap mt-1">${formatText(sp.text)}</p>` : '';
      let spEmbedHtml = '';
      if (sp.embed) {
        const spEmbedData = extractEmbedData(sp.embed);
        if (Object.keys(spEmbedData).length) {
          spEmbedHtml = renderEmbeds(spEmbedData);
        }
      }
      subjectHtml = `<div class="mt-2 rounded border border-theme-input-border p-3 bg-theme-surface/50">
        ${spText}
        ${spEmbedHtml}
      </div>`;
    }

    // Build link to the post or profile
    let clickAttr = '';
    if (n.reason === 'follow') {
      clickAttr = `data-notif-profile="${escapeHtml(a.handle)}"`;
    } else if (n.reasonSubject) {
      clickAttr = `data-notif-uri="${escapeHtml(n.reasonSubject)}"`;
    } else if (n.uri) {
      clickAttr = `data-notif-uri="${escapeHtml(n.uri)}"`;
    }

    // Action tray for notifications that point to a post.
    // Keep non-post events (follow/starterpack) card-only.
    let actionTray = '';
    const nonPostReasons = new Set(['follow', 'starterpack_joined']);
    const isOwnPost = n.reason === 'reply' || n.reason === 'mention' || n.reason === 'quote';
    const postUri = n.subjectPost?.uri || n.reasonSubject || n.uri || '';
    const hasPostUri = !!postUri && !nonPostReasons.has(n.reason);
    if (hasPostUri) {
      const postCid = n.subjectPost?.cid || n.cid || '';
      const counts = n.subjectPost || n;
      const liked = !!(n.subjectPost?.viewer?.like || n.viewer?.like || myLikes[postUri]);
      const reposted = !!(n.subjectPost?.viewer?.repost || n.viewer?.repost || myReposts[postUri]);
      const postText = n.subjectPost?.text || n.record?.text || '';
      const postHandle = n.subjectPost?.author?.handle || a.handle || '';
      const bskyLink = `https://bsky.app/profile/${postHandle}/post/${postUri.split('/').pop()}`;

      actionTray = `<div class="mt-2 pt-2 border-t border-theme-card-border flex items-center gap-3 text-xs text-theme-faint">
        <button class="bsky-reply-btn flex items-center gap-1 px-2 py-1 rounded hover:bg-theme-surface-hover transition" data-uri="${escapeHtml(postUri)}">
          ${ICON.reply} <span>${counts.replyCount || 0}</span>
        </button>
        <button class="bsky-repost-btn flex items-center gap-1 px-2 py-1 rounded hover:bg-theme-surface-hover transition ${reposted ? 'text-green-400' : ''}" data-uri="${escapeHtml(postUri)}" data-cid="${escapeHtml(postCid)}">
          ${ICON.repost} <span class="repost-count">${counts.repostCount || 0}</span>
        </button>
        <button class="bsky-like-btn flex items-center gap-1 px-2 py-1 rounded hover:bg-theme-surface-hover transition ${liked ? 'text-red-400' : ''}" data-uri="${escapeHtml(postUri)}" data-cid="${escapeHtml(postCid)}">
          ${liked ? ICON.heartFill : ICON.heart} <span class="like-count">${counts.likeCount || 0}</span>
        </button>
        <div class="ml-auto flex items-center gap-3">
          <button class="bsky-bookmark-btn flex items-center gap-1 px-2 py-1 rounded hover:bg-theme-surface-hover transition ${myBookmarks[postUri] ? 'text-blue-400' : ''}" data-uri="${escapeHtml(postUri)}" data-cid="${escapeHtml(postCid)}" data-text="${escapeHtml(postText)}" title="Save">
            ${myBookmarks[postUri] ? ICON.bookmarkFill : ICON.bookmark}
          </button>
          <button class="share-btn px-2 py-1 rounded hover:bg-theme-surface-hover transition" data-url="${escapeHtml(bskyLink)}" data-title="${escapeHtml(postText.slice(0, 100))}" title="Share">${ICON.share}</button>
          <a href="${escapeHtml(bskyLink)}" target="_blank" rel="noopener noreferrer" class="px-2 py-1 rounded hover:bg-theme-surface-hover hover:text-theme-text transition" title="View on Bluesky">${ICON.butterfly}</a>
        </div>
      </div>`;
    }

    return `<div class="rounded-lg border border-theme-card-border bg-theme-card overflow-hidden mb-2" ${clickAttr}>
      <div class="p-3">
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 relative cursor-pointer">
            ${avatar}
            <div class="absolute -bottom-1 -right-1 bg-theme-bg rounded-full p-0.5">${icon}</div>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="font-medium text-sm truncate">${escapeHtml(a.displayName)}</span>
              <span class="text-theme-faint text-xs">@${escapeHtml(a.handle)}</span>
              <span class="text-theme-faint text-xs ml-auto flex-shrink-0">${time}</span>
              ${unreadDot}
            </div>
            <p class="text-sm text-theme-muted">${label}</p>
          </div>
        </div>
        ${recordText}
        ${notifEmbedHtml}
        ${subjectHtml}
        ${actionTray}
      </div>
    </div>`;
  }

  function renderNudgeItem(nudge) {
    const from = nudge.fromUser;
    const avatar = from.avatarUrl ? `<img src="${escapeHtml(from.avatarUrl)}" alt="" class="w-10 h-10 rounded-full object-cover flex-shrink-0" loading="lazy" />` : `<div class="w-10 h-10 rounded-full bg-theme-surface flex-shrink-0 flex items-center justify-center text-theme-faint text-sm">👤</div>`;
    const time = timeAgo(nudge.createdAt);
    const msg = nudge.message ? `<p class="text-sm text-theme-muted mt-1">${escapeHtml(nudge.message)}</p>` : '';
    const unreadDot = nudge.read ? '' : '<span class="w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span>';

    return `<div class="flex items-start gap-3 p-3 rounded-lg hover:bg-theme-surface-hover transition cursor-pointer border-b border-theme-border" data-notif-profile="${escapeHtml(from.username)}">
      <div class="flex-shrink-0 relative">
        ${avatar}
        <div class="absolute -bottom-1 -right-1 bg-theme-bg rounded-full p-0.5"><span class="text-base">👋</span></div>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <span class="font-medium text-sm truncate">${escapeHtml(from.displayName || from.username)}</span>
          <span class="text-theme-faint text-xs ml-auto flex-shrink-0">${time}</span>
          ${unreadDot}
        </div>
        <p class="text-sm text-theme-muted">nudged you!</p>
        ${msg}
      </div>
    </div>`;
  }

  async function loadNotificationsTab(append = false) {
    if (isLoading) return;
    isLoading = true;
    if (!append) {
      feedContainer.innerHTML = SPINNER;
      notifCursor = null;
    }

    try {
      // Sub-navigation pills for notifications
      const subPills = `<div id="notif-pills" class="flex gap-1.5 flex-wrap mb-4">
        <button class="notif-pill ${notifSub === 'all' ? 'active-pill' : ''} rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-nsub="all">All</button>
        <button class="notif-pill ${notifSub === 'mentions' ? 'active-pill' : ''} rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-nsub="mentions">Mentions</button>
        <button class="notif-pill ${notifSub === 'nudges' ? 'active-pill' : ''} rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-nsub="nudges">Nudges</button>
        <button id="notif-mark-read" class="ml-auto rounded bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition border border-theme-border">Mark all read</button>
        <a href="${psBase}/settings/" class="rounded bg-theme-input-bg px-2 py-1 text-xs hover:bg-theme-surface-hover transition border border-theme-border inline-flex items-center" title="Notification settings">⚙</a>
      </div>`;

      if (notifSub === 'nudges') {
        // Load nudges from hub
        const res = await fetchTimeout(`${hubUrl}/api/notifications/nudges`, { headers: { Authorization: `Bearer ${token}` } });
        const data = await res.json();
        const html = (data.nudges || []).map(n => renderNudgeItem(n)).join('');

        if (!append) {
          feedContainer.innerHTML = subPills + (html || `<div class="text-center py-8 text-theme-faint">No nudges yet</div>`);
        } else {
          feedContainer.insertAdjacentHTML('beforeend', html);
        }
        hasMore = false;

        // Mark nudges as read
        try {
          await fetchTimeout(`${hubUrl}/api/notifications/nudges/read`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          });
        } catch {}
      } else {
        // Load Bluesky notifications
        const params = new URLSearchParams({ limit: '30' });
        if (notifCursor) params.set('cursor', notifCursor);
        const res = await fetchTimeout(`${hubUrl}/api/notifications/bluesky?${params}`, { headers: { Authorization: `Bearer ${token}` } });
        const data = await res.json();

        notifCursor = data.cursor || null;
        hasMore = !!notifCursor;

        let notifications = data.notifications || [];

        // Filter by sub-tab
        if (notifSub === 'mentions') {
          notifications = notifications.filter(n => n.reason === 'mention' || n.reason === 'reply' || n.reason === 'quote');
        }

        const html = notifications.map(n => renderNotificationItem(n)).join('');

        if (!append) {
          feedContainer.innerHTML = subPills + (html || `<div class="text-center py-8 text-theme-faint">No notifications</div>`);
        } else {
          feedContainer.insertAdjacentHTML('beforeend', html);
        }

        attachAllListeners();

        // Mark as seen on Bluesky (sync across devices)
        if (!append) {
          try {
            await fetchTimeout(`${hubUrl}/api/notifications/bluesky/seen`, {
              method: 'POST',
              headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
            });
            // Clear badge
            const badge = document.getElementById('notif-badge');
            if (badge) badge.setAttribute('hidden', '');
            if (navigator.clearAppBadge) navigator.clearAppBadge();
          } catch {}
        }
      }

      // Attach notification pill listeners
      document.querySelectorAll('.notif-pill').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.notif-pill').forEach(b => b.classList.remove('active-pill', 'bg-theme-surface-hover'));
          btn.classList.add('active-pill', 'bg-theme-surface-hover');
          notifSub = btn.dataset.nsub;
          notifCursor = null;
          hasMore = true;
          loadNotificationsTab();
        });
      });

      // Mark all read button
      document.getElementById('notif-mark-read')?.addEventListener('click', async () => {
        try {
          await fetchTimeout(`${hubUrl}/api/notifications/bluesky/seen`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          });
          await fetchTimeout(`${hubUrl}/api/notifications/nudges/read`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          });
          // Remove unread dots
          feedContainer.querySelectorAll('.bg-blue-500, .bg-orange-500').forEach(dot => {
            if (dot.classList.contains('w-2')) dot.remove();
          });
          const badge = document.getElementById('notif-badge');
          if (badge) badge.setAttribute('hidden', '');
          if (navigator.clearAppBadge) navigator.clearAppBadge();
        } catch {}
      });



      // Click handlers for notification items (open post thread or profile)
      feedContainer.querySelectorAll('[data-notif-uri]').forEach(el => {
        el.addEventListener('click', (e) => {
          if (e.target.closest('.bsky-like-btn, .bsky-repost-btn, .bsky-reply-btn, .bsky-bookmark-btn, .share-btn, a[target="_blank"]')) return;
          const uri = el.dataset.notifUri;
          if (uri) openThread(uri);
        });
      });
      feedContainer.querySelectorAll('[data-notif-profile]').forEach(el => {
        el.addEventListener('click', () => {
          const handle = el.dataset.notifProfile;
          if (handle && typeof openProfile === 'function') openProfile(handle);
        });
      });

    } catch (err) {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">Failed to load notifications: ${err.message}</div>`;
      hasMore = false;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  // ============================================================
  // ONLINE MODE — Direct Bluesky login (no hub token required)
  // ============================================================

  function onlineLoginForm() {
    return `<div class="rounded-lg border border-theme-border bg-theme-surface p-6 mx-auto max-w-sm mt-8">
      <div class="flex items-center gap-2 justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 18 18" fill="currentColor" class="text-theme-primary"><path d="M1.159 1.829c.284-.16.625-.174.941-.127.466.071.905.259 1.317.482.698.381 1.305.903 1.871 1.457a20.933 20.933 0 0 1 2.233 2.65c.544.768 1.063 1.558 1.48 2.403.316-.645.698-1.254 1.096-1.851a23.74 23.74 0 0 1 1.238-1.672c.466-.573.958-1.125 1.49-1.639.477-.457.983-.889 1.551-1.229a5.09 5.09 0 0 1 1.089-.501c.339-.102.702-.166 1.054-.095.258.051.497.198.651.412.205.281.282.633.311.974.021.239.01.478-.005.717a80.443 80.443 0 0 1-.221 2.776 37.19 37.19 0 0 1-.126 1.152c-.039.27-.066.544-.156.803a3.131 3.131 0 0 1-.993 1.47c-.453.371-1.005.607-1.575.729-.692.15-1.412.144-2.11.035.732.131 1.464.332 2.114.703.429.247.827.584 1.05 1.033.187.369.223.804.122 1.203-.132.535-.454 1.003-.824 1.403a6.833 6.833 0 0 1-1.028.909c-.401.28-.853.51-1.343.573a1.883 1.883 0 0 1-1.127-.203c-.45-.234-.804-.615-1.092-1.026-.462-.666-.774-1.421-1.035-2.184-.04-.108-.07-.221-.12-.325l-.025.001c-.08.184-.133.379-.204.567-.244.682-.54 1.353-.956 1.95-.209.297-.45.574-.739.796a2.097 2.097 0 0 1-.797.39 1.97 1.97 0 0 1-.947-.017 3.313 3.313 0 0 1-1.02-.485c-.336-.23-.643-.5-.929-.788-.379-.379-.718-.816-.905-1.323a1.874 1.874 0 0 1-.085-1.068c.083-.361.29-.684.555-.939.464-.446 1.063-.719 1.67-.913a7.8 7.8 0 0 1 1.087-.256 6.658 6.658 0 0 1-1.367.067c-.802-.05-1.614-.281-2.258-.776a3.092 3.092 0 0 1-.967-1.263 2.8 2.8 0 0 1-.189-.627C.858 7.71.812 7.239.763 6.769a83.74 83.74 0 0 1-.238-2.961c-.03-.438-.031-.891.113-1.312.092-.272.265-.528.521-.67Z"/></svg>
        <h2 class="text-lg font-semibold">Sign in to Bluesky</h2>
      </div>
      <div class="space-y-3">
        <input type="text" id="online-bsky-handle" placeholder="@yourhandle.bsky.social"
          class="w-full rounded bg-theme-input-bg border border-theme-input-border px-3 py-2 text-sm focus:outline-none focus:border-theme-primary"
          autocomplete="username" />
        <input type="password" id="online-bsky-password" placeholder="App Password (from Bluesky Settings)"
          class="w-full rounded bg-theme-input-bg border border-theme-input-border px-3 py-2 text-sm focus:outline-none focus:border-theme-primary"
          autocomplete="current-password" />
        <button id="online-bsky-login-btn" class="w-full rounded px-4 py-2 text-sm font-medium transition text-white" style="background:var(--ps-accent,#1185fe)">
          Sign In
        </button>
        <p id="online-bsky-error" class="text-xs text-red-400 text-center hidden"></p>
        <p class="text-xs text-theme-faint text-center">Use an App Password — Bluesky Settings → Privacy → App Passwords</p>
      </div>
      <div class="mt-4 pt-4 border-t border-theme-border text-center">
        <p class="text-xs text-theme-faint">Want your own Pirate site? <a href="/" class="text-theme-primary hover:underline">Get started free →</a></p>
      </div>
    </div>`;
  }

  async function bskyDirectLogin(handle, password) {
    const btn = document.getElementById('online-bsky-login-btn');
    const errEl = document.getElementById('online-bsky-error');
    if (btn) { btn.disabled = true; btn.textContent = 'Signing in...'; }
    if (errEl) errEl.classList.add('hidden');
    try {
      const identifier = handle.trim().replace(/^@/, '');
      const res = await fetchTimeout('https://bsky.social/xrpc/com.atproto.server.createSession', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ identifier, password }),
      }, 15000);
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.message || `Login failed (${res.status})`);
      }
      const session = await res.json();
      saveBskySession(session);
      blueskyConnected = true;
      blueskyStatusLoaded = true;
      myHandle = session.handle;
      myDid = session.did;
      // Show auth-only nav items (logout button etc.)
      document.querySelectorAll('[data-auth-only]').forEach(el => el.removeAttribute('hidden'));
      // Wire logout to clear Bluesky session
      const logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        const newBtn = logoutBtn.cloneNode(true);
        logoutBtn.parentNode?.replaceChild(newBtn, logoutBtn);
        newBtn.addEventListener('click', () => { clearCachedAuthState(); window.location.reload(); });
      }
      initSquadsProfile().catch(() => {});
      updateUI();
      loadCurrentTab();
    } catch (err) {
      if (errEl) { errEl.textContent = err.message || 'Login failed'; errEl.classList.remove('hidden'); }
      if (btn) { btn.disabled = false; btn.textContent = 'Sign In'; }
    }
  }

  function wireOnlineModeLogout() {
    const logoutBtn = document.getElementById('logout-btn');
    if (logoutBtn) {
      const newBtn = logoutBtn.cloneNode(true);
      logoutBtn.parentNode?.replaceChild(newBtn, logoutBtn);
      newBtn.addEventListener('click', () => { clearCachedAuthState(); window.location.reload(); });
    }
  }

  // ============================================================
  // INITIALIZATION
  // ============================================================
  
  // Load saved data
  loadBskySession();
  loadBookmarks();

  (async () => {
    if (await ensureHubAuth()) {
      await ensureBlueskyConnectionStatus();
      // Start init in background, don't wait for it
      initSquadsProfile().catch(err => console.warn('[PS] Squads init error:', err.message));

      // Check if we should open a specific tab (e.g. from bell icon click)
      const openTab = localStorage.getItem(authStorageKey('ps_open_tab'));
      if (openTab) {
        localStorage.removeItem(authStorageKey('ps_open_tab'));
        if (openTab === 'notifications') {
          currentTab = 'notifications';
          // Deactivate all tab buttons since notifications isn't a tab button
          document.querySelectorAll('[id^="tab-"]:not(#tab-feeds)').forEach(b => {
            b.classList.remove('active-tab', 'bg-theme-surface-hover');
            b.removeAttribute('aria-current');
            b.setAttribute('aria-selected', 'false');
            b.removeAttribute('tabindex');
          });
        }
      }

      // Online mode: wire nav/logout since BaseLayout won't have a hub token
      if (onlineMode) {
        document.querySelectorAll('[data-auth-only]').forEach(el => el.removeAttribute('hidden'));
        wireOnlineModeLogout();
      }

      updateUI();
      loadCurrentTab();
    } else {
      // Not logged in: show login form in online mode, or sign-in prompt otherwise
      if (onlineMode) {
        updateUI();
        // Feed tab will auto-show the login form via loadFeedTab
        loadCurrentTab();
      } else {
        showLoggedOutSocialState();
      }
    }
  })();
</script>

