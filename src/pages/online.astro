  /* Cursor pointer for all interactive elements */
  button, .filter-pill, .discover-pill, .search-type-pill,
  .bsky-like-btn, .bsky-repost-btn, .bsky-reply-btn, .bsky-squad-btn, .bsky-bookmark-btn,
  .share-btn, .like-btn, .comment-btn, .follow-btn, .feed-card {
    cursor: pointer;
  }
  /* Clickable post images */
  .post-img { cursor: zoom-in; }
