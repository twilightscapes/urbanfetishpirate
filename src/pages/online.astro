  function applyCachedActivity(squad) {
    const cutoff = new Date(Date.now() - squad.activityWindow * 60 * 1000);
    squad.members.forEach(m => {
      const dot = document.querySelector(`.activity-dot[data-member-id="${m.id}"]`);
      if (!dot) return;
      if (m.lastPostAt && new Date(m.lastPostAt) >= cutoff) {
        dot.classList.remove('bg-theme-surface-hover'); dot.classList.add('bg-green-500');
        dot.title = `Last posted ${timeAgo(m.lastPostAt)} (cached)`;
      } else {
        dot.title = m.lastPostAt ? `Last posted ${timeAgo(m.lastPostAt)} (cached)` : 'No data yet';
      }
    });
  }

  async function checkSquadActivity(squadId) {
    const squad = allSquads.find(s => String(s.id) === String(squadId));
    if (!squad?.members.length) return;
    const cutoff = new Date(Date.now() - squad.activityWindow * 60 * 1000);
    const results = await Promise.allSettled(
      squad.members.map(async (m) => {
        const url = `https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${encodeURIComponent(m.did || m.handle)}&limit=1&filter=posts_no_replies`;
        const res = await fetch(url);
        if (!res.ok) return { id: m.id, lastPostAt: null, isActive: false };
        const data = await res.json();
        const lastPost = data.feed?.[0]?.post;
        const lastPostAt = lastPost ? lastPost.indexedAt : null;
        return { id: m.id, lastPostAt, isActive: lastPostAt ? new Date(lastPostAt) >= cutoff : false };
      })
    );
    results.forEach(r => {
      if (r.status !== 'fulfilled') return;
      const m = r.value;
      const dot = document.querySelector(`.activity-dot[data-member-id="${m.id}"]`);
      if (!dot) return;
      if (m.isActive) { dot.classList.remove('bg-theme-surface-hover'); dot.classList.add('bg-green-500'); dot.title = `Last posted ${timeAgo(m.lastPostAt)}`; }
      else { dot.classList.remove('bg-green-500'); dot.classList.add('bg-theme-surface-hover'); dot.title = m.lastPostAt ? `Last posted ${timeAgo(m.lastPostAt)}` : 'No recent posts'; }
    });
  }

  async function fetchSquadFeedDirect(members) {
    const results = await Promise.allSettled(members.map(m => {
      return (async () => {
        const url = `https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${encodeURIComponent(m.did || m.handle)}&limit=5&filter=posts_and_author_threads`;
        const res = await fetchTimeout(url, {}, 8000);
        if (!res.ok) throw new Error(`API ${res.status}`);
        const data = await res.json();
        return (data.feed || []).map(item => normalizeBskyPost(item));
      })();
    }));
    return results.filter(r => r.status === 'fulfilled').flatMap(r => r.value).sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));
  }

  function attachSquadListeners() {
    document.querySelectorAll('.squad-window-slider').forEach(slider => {
      slider.addEventListener('input', () => {
        const label = document.querySelector(`.squad-window-label[data-squad-id="${slider.dataset.squadId}"]`);
        if (label) label.textContent = formatWindow(parseInt(slider.value));
      });
      slider.addEventListener('change', async () => {
        await fetch(`${hubUrl}/api/bluesky-feed/squads/${slider.dataset.squadId}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` }, body: JSON.stringify({ activityWindow: parseInt(slider.value) }) });
      });
    });

    // Feed toggle
    document.querySelectorAll('.squad-feed-toggle').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.squadId;
        const squad = allSquads.find(s => String(s.id) === String(id));
        if (!squad) return;
        const newVal = !squad.feedEnabled;
        squad.feedEnabled = newVal;
        btn.style.background = newVal ? 'var(--ps-accent,#3b82f6)' : 'var(--ps-input-border,#444)';
        const dot = btn.querySelector('span');
        dot.style.left = newVal ? '' : '2px';
        dot.style.right = newVal ? '2px' : '';
        const statusSpan = btn.parentElement.querySelector('.text-theme-muted');
        if (statusSpan) statusSpan.textContent = newVal ? '· In main Feed' : '· Squad-only';
        await fetch(`${hubUrl}/api/bluesky-feed/squads/${id}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` }, body: JSON.stringify({ feedEnabled: newVal }) });
      });
    });

    // Color picker per squad
    document.querySelectorAll('.squad-color-picker').forEach(picker => {
      picker.addEventListener('input', () => {
        const hex = document.querySelector(`.squad-color-hex[data-squad-id="${picker.dataset.squadId}"]`);
        if (hex) hex.textContent = picker.value;
      });
      picker.addEventListener('change', async () => {
        const id = picker.dataset.squadId;
        const squad = allSquads.find(s => String(s.id) === String(id));
        if (squad) squad.borderColor = picker.value;
        await fetch(`${hubUrl}/api/bluesky-feed/squads/${id}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` }, body: JSON.stringify({ borderColor: picker.value }) });
      });
    });

    document.querySelectorAll('.check-activity-btn').forEach(btn => {
      btn.addEventListener('click', async () => { btn.textContent = 'Checking...'; btn.disabled = true; await checkSquadActivity(btn.dataset.squadId); btn.textContent = 'Check Activity'; btn.disabled = false; });
    });

    document.querySelectorAll('.delete-squad-btn').forEach(btn => {
      btn.addEventListener('click', async () => { if (!confirm('Delete this squad?')) return; await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}`, { method: 'DELETE', headers: { Authorization: `Bearer ${token}` } }); loadSquads(); });
    });

    document.querySelectorAll('.add-member-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const input = document.querySelector(`.add-member-input[data-squad-id="${btn.dataset.squadId}"]`);
        const handle = input.value.trim();
        if (!handle) return;
        btn.textContent = '...'; btn.disabled = true;
        try {
          const res = await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}/members`, { method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` }, body: JSON.stringify({ handle }) });
          if (!res.ok) { const d = await res.json(); alert(d.error); return; }
          input.value = '';
          loadSquads();
        } catch { alert('Failed to add member'); }
        finally { btn.textContent = 'Add'; btn.disabled = false; }
      });
    });

    document.querySelectorAll('.remove-member-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        await fetch(`${hubUrl}/api/bluesky-feed/squads/${btn.dataset.squadId}/members/${btn.dataset.memberId}`, { method: 'DELETE', headers: { Authorization: `Bearer ${token}` } });
        loadSquads();
      });
    });

    document.querySelectorAll('.view-squad-feed-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const feedEl = document.querySelector(`.squad-feed[data-squad-id="${btn.dataset.squadId}"]`);
        if (!feedEl.classList.contains('hidden')) { feedEl.classList.add('hidden'); btn.textContent = 'View Squad Feed'; return; }
        const squad = allSquads.find(s => String(s.id) === btn.dataset.squadId);
        if (!squad?.members.length) return;
        btn.textContent = L.loading || 'Loading...';
        try {
          const posts = await fetchSquadFeedDirect(squad.members);
          feedEl.innerHTML = posts.map(p => renderPostCard(p)).join('') || `<div class="text-center py-4 text-theme-faint">${L.noPosts || 'No posts'}</div>`;
          feedEl.classList.remove('hidden');
          btn.textContent = 'Hide Squad Feed';
          attachAllListeners();
          initHlsVideos();
        } catch {
          feedEl.innerHTML = `<div class="text-center py-4 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
          feedEl.classList.remove('hidden');
          btn.textContent = 'Hide Squad Feed';
        }
      });
    });

    document.querySelectorAll('.squad-member-avatar').forEach(el => {
      el.addEventListener('click', () => openProfile(el.dataset.handle));
    });
  }

  // ============================================================
  // POST COMPOSER (with typo-catch delay mode)
  // ============================================================
  const composeInput = document.getElementById('compose-input');
  const composeSend = document.getElementById('compose-send');
  const composeCount = document.getElementById('compose-count');
  const composeLinkPreview = document.getElementById('compose-link-preview');
  const postDelay = document.getElementById('post-delay');
  const scheduleDatetimeInput = document.getElementById('schedule-datetime');
  const pendingPostsContainer = document.getElementById('pending-posts');
  // --- Floating compose shell (DOM-move approach) ---
  const floatingShell = document.getElementById('floating-compose-shell');
  const floatingSlot = document.getElementById('floating-compose-slot');
  const floatingCloseBtn = document.getElementById('floating-compose-close');
  const floatingTriggerBtn = document.getElementById('floating-compose-trigger');
  let composeBoxOriginalParent = null;
  let composeBoxOriginalNext = null;

  function openFloatingCompose() {
    const box = document.getElementById('compose-box');
    if (!box || !floatingShell || !floatingSlot) return;
    composeBoxOriginalParent = box.parentNode;
    composeBoxOriginalNext = box.nextSibling;
    box.style.display = '';
    floatingSlot.appendChild(box);
    floatingShell.classList.remove('translate-y-full');
    floatingShell.classList.add('translate-y-0');
    floatingShell.style.pointerEvents = '';
    if (floatingTriggerBtn) floatingTriggerBtn.classList.add('hidden');
    setTimeout(() => composeInput?.focus(), 200);
  }

  function closeFloatingCompose() {
    if (!floatingShell || !composeBoxOriginalParent) return;
    const box = document.getElementById('compose-box');
    floatingShell.classList.remove('translate-y-0');
    floatingShell.classList.add('translate-y-full');
    floatingShell.style.pointerEvents = 'none';
    if (floatingTriggerBtn) floatingTriggerBtn.classList.remove('hidden');
    setTimeout(() => {
      if (box && composeBoxOriginalParent) {
        composeBoxOriginalParent.insertBefore(box, composeBoxOriginalNext);
        box.style.display = (currentTab === 'timeline' && bskySession?.accessJwt) ? '' : 'none';
      }
    }, 300);
  }

  if (floatingTriggerBtn) floatingTriggerBtn.addEventListener('click', openFloatingCompose);
  if (floatingCloseBtn) floatingCloseBtn.addEventListener('click', closeFloatingCompose);

  // ============================================================
  // COMPOSE EXTRAS: Media Attach, Emoji Picker, Tag Groups
  // ============================================================
  let composeAttachedMedia = []; // [{blob, localUrl, type}]

  function updateComposeSendBtn() {
    if (!composeSend || !composeInput) return;
    const len = composeInput.value.length;
    composeSend.disabled = (len === 0 && !composeAttachedMedia.length) || len > 300;
    composeSend.style.opacity = composeSend.disabled ? '.5' : '1';
  }

  function renderAttachedMedia() {
    const container = document.getElementById('compose-images');
    if (!container) return;
    if (!composeAttachedMedia.length) { container.classList.add('hidden'); container.innerHTML = ''; updateComposeSendBtn(); return; }
    container.classList.remove('hidden');
    container.innerHTML = composeAttachedMedia.map((m, i) => `<div style="position:relative;display:inline-block;vertical-align:top">${m.type==='video'?`<video src="${m.localUrl}" style="height:5rem;border-radius:.5rem;object-fit:cover;background:#000;max-width:8rem" muted></video>`:`<img src="${m.localUrl}" style="height:5rem;border-radius:.5rem;object-fit:cover;max-width:8rem" />`}${!m.blob?'<div style="position:absolute;inset:0;background:rgba(0,0,0,.55);display:flex;align-items:center;justify-content:center;border-radius:.5rem"><div class="animate-spin" style="width:.9rem;height:.9rem;border:2px solid #fff;border-top-color:transparent;border-radius:50%"></div></div>':''}<button data-remove-media="${i}" style="position:absolute;top:2px;right:2px;background:rgba(0,0,0,.7);color:#fff;border:none;border-radius:50%;width:18px;height:18px;font-size:12px;cursor:pointer;line-height:1;display:flex;align-items:center;justify-content:center">×</button></div>`).join('');
    container.querySelectorAll('[data-remove-media]').forEach(btn => {
      btn.addEventListener('click', () => {
        composeAttachedMedia.splice(parseInt(btn.dataset.removeMedia), 1);
        renderAttachedMedia();
        if (!composeAttachedMedia.length) { const lp = document.getElementById('compose-link-preview'); if (lp) lp.style.display = ''; }
      });
    });
    updateComposeSendBtn();
  }

  async function uploadComposeMedia(file, idx) {
    try {
      const res = await fetch('https://bsky.social/xrpc/com.atproto.repo.uploadBlob', {
        method: 'POST',
        headers: { Authorization: `Bearer ${bskySession.accessJwt}`, 'Content-Type': file.type },
        body: file,
      });
      const data = await res.json();
      if (data.blob) { composeAttachedMedia[idx].blob = data.blob; renderAttachedMedia(); }
      else { composeAttachedMedia.splice(idx, 1); renderAttachedMedia(); }
    } catch { composeAttachedMedia.splice(idx, 1); renderAttachedMedia(); }
  }

  const EMOJIS = ['😀','😂','🤣','😊','😍','🥰','😘','😎','🤩','😭','😢','😤','😡','🤔','🤯','😱','🥺','😴','🥳','😷','🙄','😏','🫡','🫠','💀','👻','🫶','❤️','🧡','💛','💚','💙','💜','🖤','🤍','💔','❤️‍🔥','🔥','✨','🎉','🙏','👏','🤝','💪','🤞','👀','💯','✅','❌','⚡','🌟','💥','🎯','🎊','🏆','🎸','🎵','🎶','🎤','🎨','📸','📷','🌸','🌺','🌻','🌹','🍀','🌿','🌱','🌲','🌊','🌙','☀️','⭐','🌈','❄️','🦋','🐝','🐶','🐱','🦊','🐻','🦁','🐸','🐧','🦅','🍕','🍔','🌮','🍣','🍜','☕','🧋','🍰','🎂','🍩','🍫','🚀','✈️','🚗','🏠','🏖️','📱','💻','📝','📚','🎁','💰','💎','⚽','🏀','🎾','🧪','🔑','💡','🔒','📧'];

  function initComposeExtras() {
    const mediaBtn = document.getElementById('compose-media-btn');
    const mediaInput = document.getElementById('compose-media-input');
    const emojiBtn = document.getElementById('compose-emoji-btn');
    const emojiPanel = document.getElementById('compose-emoji-panel');
    const tagsBtn = document.getElementById('compose-tags-btn');

    if (mediaBtn && mediaInput) {
      mediaBtn.addEventListener('click', () => mediaInput.click());
      mediaInput.addEventListener('change', async () => {
        const files = Array.from(mediaInput.files || []);
        mediaInput.value = '';
        if (!bskySession?.accessJwt) { alert('Connect Bluesky to upload media.'); return; }
        for (const file of files) {
          const isVideo = file.type.startsWith('video/');
          const hasVideo = composeAttachedMedia.some(m => m.type === 'video');
          const imgCount = composeAttachedMedia.filter(m => m.type === 'image').length;
          if (isVideo && composeAttachedMedia.length > 0) { alert('Cannot mix video with other media.'); continue; }
          if (!isVideo && hasVideo) { alert('Cannot mix images with video.'); continue; }
          if (!isVideo && imgCount >= 4) { alert('Maximum 4 images per post.'); continue; }
          if (isVideo && file.size > 50 * 1024 * 1024) { alert('Video must be under 50 MB.'); continue; }
          if (!isVideo && file.size > 976563) { alert('Each image must be under 1 MB.'); continue; }
          const localUrl = URL.createObjectURL(file);
          const idx = composeAttachedMedia.length;
          composeAttachedMedia.push({ blob: null, localUrl, type: isVideo ? 'video' : 'image' });
          renderAttachedMedia();
          const lp = document.getElementById('compose-link-preview');
          if (lp) lp.style.display = 'none';
          uploadComposeMedia(file, idx);
        }
      });
    }

    if (emojiBtn && emojiPanel) {
      emojiPanel.innerHTML = `<div style="display:flex;flex-wrap:wrap;gap:.1rem">${EMOJIS.map(e=>`<button type="button" data-emoji="${e}" style="font-size:1.2rem;width:1.9rem;height:1.9rem;border:none;background:none;cursor:pointer;border-radius:.25rem;display:flex;align-items:center;justify-content:center">${e}</button>`).join('')}</div>`;
      emojiPanel.addEventListener('click', e => {
        const btn = e.target.closest('[data-emoji]');
        if (!btn) return;
        const inp = document.getElementById('compose-input');
        if (inp) {
          const s = inp.selectionStart, en = inp.selectionEnd, v = inp.value;
          inp.value = v.slice(0, s) + btn.dataset.emoji + v.slice(en);
          inp.selectionStart = inp.selectionEnd = s + [...btn.dataset.emoji].length;
          inp.dispatchEvent(new Event('input', { bubbles: true }));
          inp.focus();
        }
        emojiPanel.classList.add('hidden');
      });
      emojiBtn.addEventListener('click', e => { e.stopPropagation(); emojiPanel.classList.toggle('hidden'); });
      document.addEventListener('click', e => {
        if (!emojiPanel.classList.contains('hidden') && !emojiPanel.contains(e.target) && e.target !== emojiBtn) emojiPanel.classList.add('hidden');
      });
    }

    if (tagsBtn) tagsBtn.addEventListener('click', openTagGroupsModal);
  }

  // Tag groups
  const TAG_GROUPS_KEY = 'ps_tag_groups';
  let _editingGroupId = null;
  const _loadTG = () => { try { return JSON.parse(localStorage.getItem(TAG_GROUPS_KEY) || '[]'); } catch { return []; } };
  const _saveTG = g => localStorage.setItem(TAG_GROUPS_KEY, JSON.stringify(g));

  function renderTagGroupsList() {
    const container = document.getElementById('tag-groups-list');
    if (!container) return;
    const groups = _loadTG();
    if (!groups.length) { container.innerHTML = '<p style="text-align:center;padding:.75rem;font-size:.75rem;color:var(--ps-text-faint)">No groups yet — add one below.</p>'; return; }
    container.innerHTML = groups.map(g => `<div style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;background:var(--ps-input-bg);border-radius:.5rem;padding:.5rem .75rem"><div style="min-width:0;flex:1"><div style="font-size:.75rem;font-weight:600;color:var(--ps-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escapeHtml(g.name)}</div><div style="font-size:.7rem;color:var(--ps-text-faint);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escapeHtml(g.tags)}</div></div><div style="display:flex;gap:.25rem;flex-shrink:0"><button data-tg-insert="${g.id}" style="background:var(--ps-accent,#3b82f6);color:#fff;border:none;border-radius:.25rem;padding:.2rem .6rem;font-size:.7rem;cursor:pointer;white-space:nowrap">Insert</button><button data-tg-edit="${g.id}" style="background:none;border:1px solid var(--ps-border,#333);color:var(--ps-text-muted);border-radius:.25rem;padding:.2rem .5rem;font-size:.7rem;cursor:pointer">Edit</button><button data-tg-del="${g.id}" style="background:none;border:none;color:#f87171;padding:.2rem .4rem;font-size:.75rem;cursor:pointer">✕</button></div></div>`).join('');
    container.querySelectorAll('[data-tg-insert]').forEach(btn => {
      btn.addEventListener('click', () => {
        const g = _loadTG().find(x => x.id === btn.dataset.tgInsert);
        if (!g) return;
        const inp = document.getElementById('compose-input');
        if (inp) { const v = inp.value, sep = (v && !/\s$/.test(v)) ? ' ' : ''; inp.value = v + sep + g.tags; inp.dispatchEvent(new Event('input', { bubbles: true })); inp.focus(); }
        closeTagGroupsModal();
      });
    });
    container.querySelectorAll('[data-tg-edit]').forEach(btn => {
      btn.addEventListener('click', () => {
        const g = _loadTG().find(x => x.id === btn.dataset.tgEdit);
        if (!g) return;
        _editingGroupId = g.id;
        document.getElementById('tag-group-name').value = g.name;
        document.getElementById('tag-group-tags').value = g.tags;
        document.getElementById('tag-group-cancel').classList.remove('hidden');
        document.getElementById('tag-group-save').textContent = 'Update Group';
      });
    });
    container.querySelectorAll('[data-tg-del]').forEach(btn => {
      btn.addEventListener('click', () => { _saveTG(_loadTG().filter(x => x.id !== btn.dataset.tgDel)); renderTagGroupsList(); });
    });
  }

  function openTagGroupsModal() {
    const modal = document.getElementById('tag-groups-modal');
    if (!modal) return;
    _editingGroupId = null;
    const ni = document.getElementById('tag-group-name'); if (ni) ni.value = '';
    const ti = document.getElementById('tag-group-tags'); if (ti) ti.value = '';
    document.getElementById('tag-group-cancel')?.classList.add('hidden');
    const sb = document.getElementById('tag-group-save'); if (sb) sb.textContent = 'Save Group';
    renderTagGroupsList();
    modal.style.display = 'flex';
  }

  function closeTagGroupsModal() {
    const modal = document.getElementById('tag-groups-modal');
    if (modal) modal.style.display = 'none';
  }

  (function() {
    document.getElementById('tag-groups-close')?.addEventListener('click', closeTagGroupsModal);
    document.getElementById('tag-groups-backdrop')?.addEventListener('click', closeTagGroupsModal);
    document.getElementById('tag-group-cancel')?.addEventListener('click', () => {
      _editingGroupId = null;
      document.getElementById('tag-group-name').value = '';
      document.getElementById('tag-group-tags').value = '';
      document.getElementById('tag-group-cancel').classList.add('hidden');
      document.getElementById('tag-group-save').textContent = 'Save Group';
    });
    document.getElementById('tag-group-save')?.addEventListener('click', () => {
      const name = document.getElementById('tag-group-name')?.value.trim();
      const tags = document.getElementById('tag-group-tags')?.value.trim();
      if (!name || !tags) return;
      const groups = _loadTG();
      if (_editingGroupId) { const idx = groups.findIndex(g => g.id === _editingGroupId); if (idx !== -1) groups[idx] = { ...groups[idx], name, tags }; }
      else groups.push({ id: Date.now().toString(36), name, tags });
      _saveTG(groups);
      _editingGroupId = null;
      document.getElementById('tag-group-name').value = '';
      document.getElementById('tag-group-tags').value = '';
      document.getElementById('tag-group-cancel').classList.add('hidden');
      document.getElementById('tag-group-save').textContent = 'Save Group';
      renderTagGroupsList();
    });
  })();

  initComposeExtras();

  let pendingCountdowns = {};
  let getComposeCard = () => null;
  if (composeInput && composeSend) {
    getComposeCard = setupLinkPreview(composeInput, composeLinkPreview);
    composeInput.addEventListener('input', () => {
      composeCount.textContent = `${composeInput.value.length}/300`;
      updateComposeSendBtn();
    });

    // Delay dropdown — show/hide custom datetime
    if (postDelay) {
      postDelay.addEventListener('change', () => {
        if (postDelay.value === 'custom') {
          const d = new Date(Date.now() + 3600_000);
          d.setMinutes(Math.ceil(d.getMinutes() / 5) * 5, 0, 0);
          scheduleDatetimeInput.value = d.toISOString().slice(0, 16);
          scheduleDatetimeInput.classList.remove('hidden');
        } else {
          scheduleDatetimeInput.classList.add('hidden');
          scheduleDatetimeInput.value = '';
        }
        composeSend.textContent = 'Post';
      });
    }



    composeSend.addEventListener('click', async () => {
      const text = composeInput.value.trim();
      if (!text && !composeAttachedMedia.length) return;
      if (composeAttachedMedia.some(m => !m.blob)) { alert('Media is still uploading, please wait.'); return; }
      const delaySec = postDelay ? postDelay.value : '0';

      if (delaySec === '0') {
        // Post immediately via Bluesky
        if (!bskySession?.accessJwt) return;
        composeSend.disabled = true;
        composeSend.textContent = 'Posting...';
        try {
          await createBskyRecord(text, null, composeAttachedMedia.length ? null : getComposeCard(), composeAttachedMedia.slice());
          composeInput.value = '';
          composeCount.textContent = '0/300';
          getComposeCard.clear?.();
          composeAttachedMedia = []; renderAttachedMedia();
          composeSend.textContent = 'Post';
          composeSend.disabled = true;
          composeSend.style.opacity = '.5';
          closeFloatingCompose();
          resetPagination();
          loadFeedTab();
        } catch (err) {
          console.error('Post error:', err);
          composeSend.textContent = 'Failed — Retry';
          composeSend.disabled = false;
          composeSend.style.opacity = '1';
        }
      } else {
        // Delayed / scheduled post via hub
        if (!token) return;
        composeSend.disabled = true;
        composeSend.textContent = 'Scheduling...';
        let scheduledAt;
        if (delaySec === 'custom') {
          if (!scheduleDatetimeInput.value) { composeSend.disabled = false; composeSend.textContent = 'Post'; return; }
          scheduledAt = new Date(scheduleDatetimeInput.value).toISOString();
        } else {
          scheduledAt = new Date(Date.now() + parseInt(delaySec, 10) * 1000).toISOString();
        }
        try {
          const res = await fetch(`${hubUrl}/api/scheduled`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
            body: JSON.stringify({ text, scheduledAt, linkCard: getComposeCard?.() || null }),
          });
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            throw new Error(err.error || 'Schedule failed');
          }
          composeInput.value = '';
          composeCount.textContent = '0/300';
          getComposeCard.clear?.();
          composeAttachedMedia = []; renderAttachedMedia();
          composeSend.textContent = 'Post';
          composeSend.disabled = true;
          composeSend.style.opacity = '.5';
          closeFloatingCompose();
          scheduleDatetimeInput.classList.add('hidden');
          scheduleDatetimeInput.value = '';
          loadScheduledPosts();
          renderPendingPosts();
        } catch (err) {
          console.error('Schedule error:', err);
          composeSend.textContent = 'Failed — Retry';
          composeSend.disabled = false;
          composeSend.style.opacity = '1';
        }
      }
    });

    // ---- Pending posts (typo-catch countdown cards) ----
    async function renderPendingPosts() {
      if (!token || !pendingPostsContainer) return;
      // Fetch profile for avatar if we don't have it yet
      if (!myAvatar && bskySession?.handle) {
        try {
          const profileRes = await fetchTimeout(`https://public.api.bsky.app/xrpc/app.bsky.actor.getProfile?actor=${encodeURIComponent(bskySession.handle)}`, {}, 8000);
          if (profileRes.ok) { const profile = await profileRes.json(); myAvatar = profile.avatar || null; myDisplayName = profile.displayName || bskySession.handle; myHandle = bskySession.handle; }
        } catch {}
      }
      // Clear old countdowns
      Object.values(pendingCountdowns).forEach(id => clearInterval(id));
      pendingCountdowns = {};
      try {
        const res = await fetch(`${hubUrl}/api/scheduled?status=pending`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        if (!res.ok) return;
        const posts = await res.json();
        // Only show posts scheduled within the next 10 minutes as "pending" cards
        const soon = posts.filter(p => new Date(p.scheduledAt).getTime() - Date.now() < 600_000);
        const later = posts.filter(p => new Date(p.scheduledAt).getTime() - Date.now() >= 600_000);
        if (soon.length === 0 && later.length === 0) {
          pendingPostsContainer.innerHTML = '';
          return;
        }
        let html = '';
        const avatarHtml = myAvatar ? `<img src="${escapeHtml(myAvatar)}" class="h-10 w-10 rounded-full" />` : '<div class="h-10 w-10 rounded-full bg-theme-surface-hover"></div>';
        const displayName = escapeHtml(myDisplayName || myHandle || 'You');
        const handle = escapeHtml(myHandle || '');
        soon.forEach(p => {
          const card = p.linkCard;
          const cardHtml = card && !card.removed && card.url ? `
            <a href="${escapeHtml(card.url)}" target="_blank" rel="noopener noreferrer" class="mt-2 block rounded-lg overflow-hidden border border-theme-card-border bg-theme-surface hover:bg-theme-surface-hover transition">
              ${card.image ? `<img src="${escapeHtml(card.image)}" alt="" class="w-full aspect-[2/1] object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
              <div class="p-3">
                ${card.title ? `<div class="font-medium text-sm text-theme-text mb-1">${escapeHtml(card.title)}</div>` : ''}
                ${card.description ? `<div class="text-xs text-theme-muted line-clamp-2">${escapeHtml(card.description)}</div>` : ''}
                <div class="mt-1 text-xs text-theme-faint truncate">${escapeHtml(card.url.replace(/^https?:\/\//, ''))}</div>
              </div>
            </a>` : '';
          html += `<article id="pending-${p.id}" class="rounded-lg border border-theme-card-border bg-theme-card overflow-hidden" style="border-left: 3px solid rgb(234 179 8)">
            <div class="p-4">
              <div class="flex items-center gap-3 mb-3">
                ${avatarHtml}
                <div class="min-w-0 flex-1">
                  <span class="font-medium text-sm">${displayName}</span>
                  <div class="text-xs text-theme-faint">@${handle}</div>
                </div>
                <span class="text-yellow-400 text-xs font-medium whitespace-nowrap">⏳ <span class="pending-countdown" data-until="${p.scheduledAt}"></span></span>
              </div>
              <div class="pending-text text-sm whitespace-pre-wrap mb-2" data-id="${p.id}">${formatText(p.text)}</div>
              ${cardHtml}
              <div class="pending-edit-area hidden mb-2" data-id="${p.id}">
                <textarea class="w-full rounded bg-theme-input-bg border border-theme-input-border p-2 text-sm text-theme-text resize-vertical" rows="3" maxlength="300">${escapeHtml(p.text)}</textarea>
                <div class="flex justify-end gap-1 mt-1">
                  <button class="pending-save text-xs px-2 py-1 rounded bg-theme-primary text-white hover:opacity-80 transition" data-id="${p.id}">Save</button>
                  <button class="pending-edit-cancel text-xs px-2 py-1 rounded bg-theme-surface-hover text-theme-text hover:opacity-80 transition" data-id="${p.id}">Cancel</button>
                </div>
              </div>
              <div class="flex items-center gap-2 text-xs mt-3">
                <button class="pending-edit flex items-center gap-1 px-2 py-1 rounded hover:bg-theme-surface-hover text-theme-faint hover:text-theme-text transition" data-id="${p.id}" data-text="${escapeHtml(p.text)}">${ICON.edit || '✏️'} Edit</button>
                <button class="pending-send flex items-center gap-1 px-2 py-1 rounded bg-green-600/20 text-green-400 hover:bg-green-600/40 transition" data-id="${p.id}">▶ Send Now</button>
                <button class="pending-cancel flex items-center gap-1 px-2 py-1 rounded hover:bg-red-600/20 text-theme-faint hover:text-red-400 transition" data-id="${p.id}">✕ Cancel</button>
              </div>
            </div>
          </article>`;
        });
        pendingPostsContainer.innerHTML = html;

        // Start countdowns
        pendingPostsContainer.querySelectorAll('.pending-countdown').forEach(el => {
          const until = new Date(el.dataset.until).getTime();
          const update = () => {
            const left = Math.max(0, until - Date.now());
            if (left <= 0) { el.textContent = 'sending...'; renderPendingPosts(); return; }
            const s = Math.ceil(left / 1000);
            el.textContent = s >= 60 ? `${Math.floor(s / 60)}m ${s % 60}s` : `${s}s`;
          };
          update();
          const id = setInterval(update, 1000);
          const postId = el.closest('[id^="pending-"]')?.id?.replace('pending-', '');
          if (postId) pendingCountdowns[postId] = id;
        });

        // Edit button
        pendingPostsContainer.querySelectorAll('.pending-edit').forEach(btn => {
          btn.addEventListener('click', () => {
            const id = btn.dataset.id;
            const textEl = pendingPostsContainer.querySelector(`.pending-text[data-id="${id}"]`);
            const editArea = pendingPostsContainer.querySelector(`.pending-edit-area[data-id="${id}"]`);
            if (textEl) textEl.classList.add('hidden');
            if (editArea) editArea.classList.remove('hidden');
            btn.classList.add('hidden');
          });
        });

        // Save edit
        pendingPostsContainer.querySelectorAll('.pending-save').forEach(btn => {
          btn.addEventListener('click', async () => {
            const id = btn.dataset.id;
            const editArea = pendingPostsContainer.querySelector(`.pending-edit-area[data-id="${id}"]`);
            const newText = editArea?.querySelector('textarea')?.value?.trim();
            if (!newText) return;
            btn.textContent = 'Saving...';
            try {
              await fetch(`${hubUrl}/api/scheduled/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                body: JSON.stringify({ text: newText }),
              });
              renderPendingPosts();
            } catch { btn.textContent = 'Save'; }
          });
        });

        // Cancel edit (revert)
        pendingPostsContainer.querySelectorAll('.pending-edit-cancel').forEach(btn => {
          btn.addEventListener('click', () => {
            const id = btn.dataset.id;
            const textEl = pendingPostsContainer.querySelector(`.pending-text[data-id="${id}"]`);
            const editArea = pendingPostsContainer.querySelector(`.pending-edit-area[data-id="${id}"]`);
            const editBtn = pendingPostsContainer.querySelector(`.pending-edit[data-id="${id}"]`);
            if (textEl) textEl.classList.remove('hidden');
            if (editArea) editArea.classList.add('hidden');
            if (editBtn) editBtn.classList.remove('hidden');
          });
        });

        // Send Now
        pendingPostsContainer.querySelectorAll('.pending-send').forEach(btn => {
          btn.addEventListener('click', async () => {
            btn.textContent = 'Sending...';
            btn.disabled = true;
            try {
              await fetch(`${hubUrl}/api/scheduled/${btn.dataset.id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                body: JSON.stringify({ postNow: true }),
              });
              // Brief pause for scheduler to pick it up
              setTimeout(() => { renderPendingPosts(); resetPagination(); loadFeedTab(); }, 2000);
            } catch { btn.textContent = 'Send Now'; btn.disabled = false; }
          });
        });

        // Cancel post
        pendingPostsContainer.querySelectorAll('.pending-cancel').forEach(btn => {
          btn.addEventListener('click', async () => {
            btn.textContent = '...';
            try {
              await fetch(`${hubUrl}/api/scheduled/${btn.dataset.id}`, {
                method: 'DELETE',
                headers: { Authorization: `Bearer ${token}` },
              });
              renderPendingPosts();
            } catch { btn.textContent = 'Cancel'; }
          });
        });
      } catch {}
    }

    // Load and display far-future scheduled posts (in compose area)
    async function loadScheduledPosts() {
      if (!token) return;
      const container = document.getElementById('scheduled-posts-list');
      if (!container) return;
      try {
        const res = await fetch(`${hubUrl}/api/scheduled?status=pending`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        if (!res.ok) return;
        const posts = await res.json();
        // Only show posts scheduled more than 10 min out
        const later = posts.filter(p => new Date(p.scheduledAt).getTime() - Date.now() >= 600_000);
        if (later.length === 0) { container.classList.add('hidden'); container.innerHTML = ''; return; }
        container.classList.remove('hidden');
        container.innerHTML = `<div class="text-xs font-medium text-theme-muted mb-2">Scheduled (${later.length})</div>` +
          later.map(p => `<div class="flex items-start justify-between gap-2 py-2 border-b border-theme-border last:border-0 text-xs">
            <div class="flex-1 min-w-0">
              <div class="text-theme-text truncate">${escapeHtml(p.text)}</div>
              <div class="text-theme-faint mt-0.5">${new Date(p.scheduledAt).toLocaleString()}</div>
            </div>
            <button class="cancel-scheduled text-theme-faint hover:text-red-400 transition flex-shrink-0" data-id="${p.id}" title="Cancel">✕</button>
          </div>`).join('');
        container.querySelectorAll('.cancel-scheduled').forEach(btn => {
          btn.addEventListener('click', async () => {
            if (!confirm('Cancel this scheduled post?')) return;
            await fetch(`${hubUrl}/api/scheduled/${btn.dataset.id}`, {
              method: 'DELETE',
              headers: { Authorization: `Bearer ${token}` },
            });
            loadScheduledPosts();
            renderPendingPosts();
          });
        });
      } catch {}
    }
    // Load on init
    loadScheduledPosts();
    renderPendingPosts();
  }

