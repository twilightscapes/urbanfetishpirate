  // Delegated handler for sign-in button (dynamically injected into feed-container)
  feedContainer.addEventListener('click', (e) => {
    if (e.target?.id === 'social-login') {
      if (onlineMode) {
        feedContainer.innerHTML = onlineLoginForm();
        document.getElementById('online-bsky-login-btn')?.addEventListener('click', () => {
          const h = document.getElementById('online-bsky-handle')?.value || '';
          const p = document.getElementById('online-bsky-password')?.value || '';
          if (h && p) bskyDirectLogin(h, p);
        });
        document.getElementById('online-bsky-password')?.addEventListener('keydown', (ev) => {
          if (ev.key === 'Enter') {
            const h = document.getElementById('online-bsky-handle')?.value || '';
            const p = document.getElementById('online-bsky-password')?.value || '';
            if (h && p) bskyDirectLogin(h, p);
          }
        });
      } else {
        window.location.href = `${hubUrl}/api/auth/github?site=${encodeURIComponent(window.location.origin + (psBase || '/'))}`;
      }
    }
  });

  // ============================================================
  // FEED TAB — Bluesky timeline + Pirate RSS merged
  // ============================================================
  async function loadSavedPosts() {
    feedContainer.innerHTML = SPINNER;
    scrollSentinel.classList.add('hidden');
    try {
      const bookmarkUris = Object.keys(myBookmarks).filter(u => u.startsWith('at://'));
      if (!bookmarkUris.length) {
        feedContainer.innerHTML = '<div class="text-center py-8 text-theme-faint">No saved posts yet. Tap the bookmark icon on any post to save it.</div>';
        return;
      }
      // Fetch posts in batches of 25 (API limit)
      const allPosts = [];
      for (let i = 0; i < bookmarkUris.length; i += 25) {
        const batch = bookmarkUris.slice(i, i + 25);
        try {
          const uriParams = batch.map(u => `uris=${encodeURIComponent(u)}`).join('&');
          const url = `${BSKY_PUBLIC}/app.bsky.feed.getPosts?${uriParams}`;
          const res = await fetchTimeout(url, {}, 10000);
          if (res.ok) {
            const data = await res.json();
            if (data?.posts) {
              allPosts.push(...data.posts.map(p => normalizeBskyPost({ post: p })));
            }
          }
        } catch (err) { console.warn('[PS] getPosts batch error:', err.message); }
      }
      // Deduplicate by URI
      const seen = new Set();
      const unique = allPosts.filter(p => { if (seen.has(p.uri)) return false; seen.add(p.uri); return true; });
      // Sort by bookmark date (newest first)
      unique.sort((a, b) => {
        const aDate = myBookmarks[a.uri]?.savedAt || a.pubDate;
        const bDate = myBookmarks[b.uri]?.savedAt || b.pubDate;
        return new Date(bDate) - new Date(aDate);
      });
      if (!unique.length) {
        feedContainer.innerHTML = '<div class="text-center py-8 text-theme-faint">No saved posts found.</div>';
        return;
      }
      feedContainer.innerHTML = unique.map(p => renderPostCard(p)).join('');
      attachAllListeners();
      initHlsVideos();
    } catch (err) {
      feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">Failed to load saved posts: ${err.message}</div>`;
    }
  }

  async function loadFeedTab(append = false) {
    if (isLoading) return;
    isLoading = true;
    if (!append) { feedContainer.innerHTML = SPINNER; }
    scrollSentinel.classList.toggle('hidden', !append);

    try {
      const session = await ensureBskySession();
      let allPosts = [];
      let hasBlueskyError = false;

      // Fetch Bluesky timeline (direct AT Protocol)
      if (session?.accessJwt) {
        try {
          const bskyData = await fetchBskyTimeline(bskyCursor);
          bskyCursor = bskyData.cursor || null;
          const bskyPosts = (bskyData.feed || []).map(item => normalizeBskyPost(item));
          allPosts.push(...bskyPosts);
        } catch (err) {
          console.error('[PS] Bluesky timeline error:', err.message);
          hasBlueskyError = true;
        }
      }

      // Fetch squad member posts and merge into timeline
      if (session?.accessJwt && !append) {
        try {
          if (!allSquads.length && token) {
            const sRes = await fetchTimeout(`${hubUrl}/api/bluesky-feed/squads`, { headers: { Authorization: `Bearer ${token}` } });
            allSquads = await sRes.json();
          }
          if (allSquads.length) {
            // Build squad member lookup: handle -> border color
            squadMemberHandles = new Map();
            for (const squad of allSquads) {
              const color = squad.borderColor || '#eab308';
              for (const m of (squad.members || [])) {
                if (!squadMemberHandles.has(m.handle)) squadMemberHandles.set(m.handle, color);
              }
            }
            const seenDids = new Set();
            const uniqueMembers = [];
            for (const squad of allSquads) {
              if (squad.feedEnabled === false) continue;
              for (const m of (squad.members || [])) {
                const key = m.did || m.handle;
                if (!seenDids.has(key)) { seenDids.add(key); uniqueMembers.push(m); }
              }
            }
            if (uniqueMembers.length) {
              const squadPosts = await fetchSquadFeedDirect(uniqueMembers);
              // Deduplicate — skip posts already in timeline
              const existingUris = new Set(allPosts.map(p => p.uri));
              allPosts.push(...squadPosts.filter(p => !existingUris.has(p.uri)));
            }
          }
        } catch (err) {
          console.error('[PS] Squad feed merge error:', err.message);
          hasBlueskyError = true;
        }
      }

      // Fetch Pirate Social timeline (RSS + pirate posts) — only on first load or if filter is pirate
      if (token && (!append || currentFilter === 'pirate' || currentFilter === 'all')) {
        try {
          const headers = { Authorization: `Bearer ${token}` };
          const pirateRes = await fetchTimeout(`${hubUrl}/api/timeline?page=${piratePage}`, { headers });
          const pirateData = await pirateRes.json();
          const piratePosts = (pirateData.posts || []).map(p => normalizePiratePost(p));
          allPosts.push(...piratePosts);
          if (!pirateData.hasMore && !bskyCursor) hasMore = false;
        } catch (err) {
          console.error('[PS] Pirate timeline error:', err.message);
        }
      }

      // Fetch YouTube subscription videos (channels with feedEnabled)
      if (token && !append) {
        try {
          if (!youtubeChannels.length) {
            const ytRes = await fetchTimeout(`${hubUrl}/api/youtube/channels`, { headers: { Authorization: `Bearer ${token}` } });
            if (ytRes.ok) youtubeChannels = await ytRes.json();
          }
          const feedChannels = youtubeChannels.filter(ch => ch.feedEnabled);
          const ytFetches = feedChannels.map(ch =>
            fetchTimeout(`${hubUrl}/api/youtube/feed?channelId=${encodeURIComponent(ch.channelId)}&max=${ch.videoCount || 5}`)
              .then(r => r.ok ? r.json() : { videos: [] })
              .catch(() => ({ videos: [] }))
          );
          const ytResults = await Promise.all(ytFetches);
          for (const { videos } of ytResults) {
            for (const v of (videos || [])) {
              allPosts.push({
                type: 'youtube',
                id: `yt-${v.videoId}`,
                author: { handle: v.channelTitle, displayName: v.channelTitle, avatar: '', isYouTube: true },
                text: v.description || '',
                title: v.title,
                pubDate: v.publishedAt,
                videoId: v.videoId,
                thumbnail: v.thumbnail,
                link: `https://youtube.com/watch?v=${v.videoId}`,
              });
            }
          }
        } catch (err) {
          console.error('[PS] YouTube feed error:', err.message);
        }
      }

      // If no Bluesky session and no token, show discover
      if (!session?.accessJwt && !token) {
        try {
          const pirateRes = await fetchTimeout(`${hubUrl}/api/timeline/discover?page=${piratePage}`);
          const pirateData = await pirateRes.json();
          allPosts = (pirateData.posts || []).map(p => normalizePiratePost(p));
          hasMore = !!pirateData.hasMore;
        } catch {}
      }

      // Sort by date
      allPosts.sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));

      // Apply filter
      const filtered = allPosts.filter(p => matchesFilter(p, currentFilter));

      hasMore = !!bskyCursor || hasMore;

      const html = filtered.map(p => renderPostCard(p)).join('');
      // Build sign-in banner for guests (shown regardless of post count)
      const guestBanner = !token ? `<div class="rounded-lg border border-theme-border bg-theme-surface p-4 text-center mb-4"><p class="text-sm text-theme-muted mb-3">${L.signInPrompt || 'Sign in to see your personalized feed'}</p><button id="social-login" class="rounded bg-theme-primary text-white px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">${onlineMode ? 'Sign in with Bluesky' : (L.signInButton || 'Sign in with GitHub')}</button></div>` : '';

      if (append) {
        feedContainer.insertAdjacentHTML('beforeend', html);
      } else {
        if (!token && !filtered.length) {
          // Guest with no posts: show full-page sign-in prompt
          feedContainer.innerHTML = onlineMode
            ? onlineLoginForm()
            : `<div class="text-center text-theme-faint py-12"><p>${L.signInPrompt || 'Sign in to see your feed'}</p><button id="social-login" class="mt-4 rounded bg-theme-primary text-white px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">${L.signInButton || 'Sign in with GitHub'}</button></div>`;
          if (onlineMode) {
            document.getElementById('online-bsky-login-btn')?.addEventListener('click', () => {
              const h = document.getElementById('online-bsky-handle')?.value || '';
              const p = document.getElementById('online-bsky-password')?.value || '';
              if (h && p) bskyDirectLogin(h, p);
            });
            document.getElementById('online-bsky-password')?.addEventListener('keydown', (ev) => {
              if (ev.key === 'Enter') {
                const h = document.getElementById('online-bsky-handle')?.value || '';
                const p = document.getElementById('online-bsky-password')?.value || '';
                if (h && p) bskyDirectLogin(h, p);
              }
            });
          }
        } else if (!token && filtered.length) {
          // Guest with public posts: show banner then posts
          feedContainer.innerHTML = guestBanner + html;
        } else if (!filtered.length) {
          if (hasBlueskyError) {
            feedContainer.innerHTML = `<div class="text-center py-8"><div class="text-theme-faint mb-3">⚠️ Unable to load Bluesky feed</div><p class="text-sm text-theme-muted mb-4">Try connecting Bluesky in Settings or refreshing the page</p><button id="refresh-feed" class="rounded bg-theme-primary px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">↻ Retry</button></div>`;
            document.getElementById('refresh-feed')?.addEventListener('click', loadFeedTab);
          } else if (session?.accessJwt) {
            feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.noPosts || 'No posts yet'}</div>`;
          } else {
            // Logged in but no Bluesky: guide them to Settings
            feedContainer.innerHTML = onlineMode
              ? `<div class="rounded-lg border border-theme-border bg-theme-surface p-6 text-center"><p class="text-sm text-theme-muted mb-3">Sign in with Bluesky to see your feed</p><button id="social-login" class="rounded bg-theme-primary text-white px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">Sign in with Bluesky</button></div>`
              : `<div class="rounded-lg border border-theme-border bg-theme-surface p-6 text-center"><p class="text-sm text-theme-muted mb-3">${L.connectBluesky || 'Connect your Bluesky account in Settings to see your feed'}</p><a href="${psBase}/settings/bluesky" class="rounded bg-theme-primary text-white px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">Open Settings</a></div>`;
          }
        } else {
          feedContainer.innerHTML = html;
        }
      }
      attachAllListeners();
      initHlsVideos();
    } catch (err) {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load feed'}: ${err.message}</div>`;
      hasMore = false;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  // ============================================================
  // DISCOVER TAB
  // ============================================================
  async function loadDiscoverTab() {
    if (currentDiscoverSub === 'trending') loadDiscoverTrending();
    else if (currentDiscoverSub === 'people') loadDiscoverPeople();
    else if (currentDiscoverSub === 'feeds') loadDiscoverFeeds();
  }

  async function loadDiscoverTrending(append = false) {
    if (isLoading) return;
    isLoading = true;
    if (!append) feedContainer.innerHTML = SPINNER;
    scrollSentinel.classList.toggle('hidden', !append);

    try {
      const session = await ensureBskySession();
      const allowBlueskyDiscover = (onlineMode ? !!session?.accessJwt : (!!token && !!session?.accessJwt));
      let allPosts = [];

      // Trending topics banner
      let trendingHtml = '';
      if (!append && allowBlueskyDiscover) {
        try {
          const trending = await fetchTrendingTopics();
          if (trending.topics?.length || trending.suggested?.length) {
            const topics = [...(trending.topics || []), ...(trending.suggested || [])].slice(0, 12);
            trendingHtml = `<div class="flex gap-2 flex-wrap mb-6">${topics.map(t =>
              `<button class="trending-topic rounded-full bg-theme-input-bg border border-theme-input-border px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-topic="${escapeHtml(t.topic || t.tag || t)}">#${escapeHtml(t.topic || t.tag || t)}</button>`
            ).join('')}</div>`;
          }
        } catch {}
      }

      // Bluesky discover feed
      if (allowBlueskyDiscover) {
        try {
          const data = await fetchBskyDiscover(bskyCursor);
          bskyCursor = data.cursor || null;
          allPosts = (data.feed || []).map(item => normalizeBskyPost(item));
        } catch {}
      }

      // Also pull Pirate Social discover
      try {
        const pirateRes = await fetchTimeout(`${hubUrl}/api/timeline/discover?page=${piratePage}`);
        const pirateData = await pirateRes.json();
        allPosts.push(...(pirateData.posts || []).map(p => normalizePiratePost(p)));
      } catch {}

      allPosts.sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));
      hasMore = !!bskyCursor;

      const html = allPosts.map(p => renderPostCard(p)).join('');
      if (append) {
        feedContainer.insertAdjacentHTML('beforeend', html);
      } else {
        feedContainer.innerHTML = trendingHtml + (html || `<div class="text-center py-8 text-theme-faint">${L.noPosts || 'No posts'}</div>`);
      }
      attachAllListeners();
      initHlsVideos();

      // Attach trending topic click handlers — search posts for that topic
      document.querySelectorAll('.trending-topic').forEach(btn => {
        btn.addEventListener('click', async () => {
          if (!allowBlueskyDiscover) return;
          const topic = btn.dataset.topic;
          if (!topic) return;
          feedContainer.innerHTML = SPINNER;
          try {
            const data = await searchBskyPosts(topic);
            const posts = (data.posts || []).map(p => normalizeBskyPost({ post: p }));
            const backBtn = `<button id="back-to-discover" class="flex items-center gap-1 text-sm text-theme-muted hover:text-theme-text transition mb-4">← Back to discover</button>
              <h2 class="text-lg font-semibold mb-4">#${escapeHtml(topic)}</h2>`;
            feedContainer.innerHTML = backBtn + (posts.map(p => renderPostCard(p)).join('') || `<div class="text-center py-8 text-theme-faint">No posts found</div>`);
            document.getElementById('back-to-discover')?.addEventListener('click', () => {
              resetPagination();
              loadDiscoverTrending();
            });
            attachAllListeners();
            initHlsVideos();
          } catch {
            feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">Search failed</div>`;
          }
        });
      });
    } catch {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  async function loadDiscoverPeople(append = false) {
    if (isLoading) return;
    isLoading = true;
    const query = document.getElementById('discover-search-input')?.value.trim() || '';
    if (!append) {
      feedContainer.innerHTML = SPINNER;
    }

    try {
      const headers = token ? { Authorization: `Bearer ${token}` } : {};
      const qParam = query ? `&q=${encodeURIComponent(query)}` : '';

      // Pirate Social directory
      const pirateRes = await fetchTimeout(`${hubUrl}/api/directory?page=${piratePage}&limit=25${qParam}`, { headers });
      const pirateData = await pirateRes.json();
      const pirateHtml = (pirateData.users || []).map(u => renderPirateUserCard(u)).join('');

      // Also search Bluesky users if we have a query
      let bskyHtml = '';
      if (query) {
        try {
          const bskyData = await searchBskyActors(query, append ? bskyCursor : null);
          bskyCursor = bskyData.cursor || null;
          bskyHtml = (bskyData.actors || []).map(a => renderBskyUserCard(a)).join('');
        } catch {}
      }

      hasMore = !!pirateData.hasMore || !!bskyCursor;
      const html = pirateHtml + bskyHtml;

      if (append) {
        feedContainer.insertAdjacentHTML('beforeend', html);
      } else {
        feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">${query ? `No users found for "${escapeHtml(query)}"` : (L.noUsers || 'No users yet')}</div>`;
      }
      attachAllListeners();
    } catch {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  async function loadDiscoverFeeds(append = false) {
    if (isLoading) return;
    isLoading = true;
    const query = document.getElementById('discover-search-input')?.value.trim() || '';
    if (!append) {
      feedContainer.innerHTML = SPINNER;
    }

    try {
      const data = await searchBskyFeeds(query, append ? bskyCursor : null);
      bskyCursor = data.cursor || null;
      hasMore = !!bskyCursor;
      const feeds = data.feeds || [];
      const html = feeds.map(f => renderFeedCard(f)).join('');
      if (append) {
        feedContainer.insertAdjacentHTML('beforeend', html);
      } else {
        feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">${query ? `No feeds found for "${escapeHtml(query)}"` : 'No feeds found'}</div>`;
      }
      attachAllListeners();
    } catch {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  let activeFeedUri = null;
  let activeFeedName = null;

  async function loadCustomFeedView(feedUri, feedName, append = false) {
    activeFeedUri = feedUri;
    activeFeedName = feedName;
    if (isLoading) return;
    isLoading = true;
    if (!append) {
      bskyCursor = null;
      feedContainer.innerHTML = SPINNER;
    }

    try {
      const data = await fetchCustomFeed(feedUri, bskyCursor);
      bskyCursor = data.cursor || null;
      hasMore = !!bskyCursor;
      const posts = (data.feed || []).map(item => normalizeBskyPost(item));
      const html = posts.map(p => renderPostCard(p)).join('');

      const subbed = isSubscribed(feedUri);
      const subBtn = `<button id="feed-view-sub" class="text-xs px-2 py-0.5 rounded ${subbed ? 'bg-red-500/20 text-red-400 hover:bg-red-500/30' : 'bg-theme-primary/20 text-theme-primary hover:bg-theme-primary/30'} transition ml-2">${subbed ? '− Remove from Feeds' : '+ Add to Feeds'}</button>`;
      const backLabel = currentTab === 'feeds' ? '← Back' : '← Back to feeds';
      const backBtn = `<div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <button id="back-to-feeds" class="flex items-center gap-1 text-sm text-theme-muted hover:text-theme-text transition">${backLabel}</button>
          <h2 class="text-lg font-semibold">${escapeHtml(feedName)}</h2>
        </div>
        ${subBtn}
      </div>`;

      if (append) {
        feedContainer.insertAdjacentHTML('beforeend', html);
      } else {
        feedContainer.innerHTML = backBtn + (html || `<div class="text-center py-8 text-theme-faint">${L.noPosts || 'No posts'}</div>`);
        document.getElementById('back-to-feeds')?.addEventListener('click', () => {
          activeFeedUri = null;
          resetPagination();
          if (currentTab === 'feeds') {
            // Go back to timeline
            setActiveTab(document.getElementById('tab-timeline'));
            feedsDropdown.value = '';
            currentTab = 'timeline';
            updateUI();
            loadFeedTab();
          } else {
            loadDiscoverFeeds();
          }
        });
        document.getElementById('feed-view-sub')?.addEventListener('click', (e) => {
          if (isSubscribed(feedUri)) {
            unsubscribeFeed(feedUri);
            e.target.textContent = '+ Add to Feeds';
            e.target.className = e.target.className.replace(/bg-red-500\/20 text-red-400 hover:bg-red-500\/30/, 'bg-theme-primary/20 text-theme-primary hover:bg-theme-primary/30');
          } else {
            subscribeFeed(feedUri, feedName, '');
            e.target.textContent = '− Remove from Feeds';
            e.target.className = e.target.className.replace(/bg-theme-primary\/20 text-theme-primary hover:bg-theme-primary\/30/, 'bg-red-500/20 text-red-400 hover:bg-red-500/30');
          }
        });
      }
      attachAllListeners();
      initHlsVideos();
    } catch {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad || 'Failed to load'}</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  // ============================================================
  // SEARCH TAB
  // ============================================================
  async function loadSearchResults(append = false) {
    const query = document.getElementById('search-input').value.trim();
    if (!query) return;
    if (isLoading) return;
    isLoading = true;
    if (!append) feedContainer.innerHTML = SPINNER;

    try {
      if (currentSearchType === 'posts') {
        const data = await searchBskyPosts(query, bskyCursor);
        bskyCursor = data.cursor || null;
        hasMore = !!bskyCursor;
        const posts = (data.posts || []).map(p => normalizeBskyPost({ post: p }));
        const html = posts.map(p => renderPostCard(p)).join('');
        if (append) feedContainer.insertAdjacentHTML('beforeend', html);
        else feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No results for "${escapeHtml(query)}"</div>`;
      } else if (currentSearchType === 'users') {
        const data = await searchBskyActors(query, bskyCursor);
        bskyCursor = data.cursor || null;
        hasMore = !!bskyCursor;
        const html = (data.actors || []).map(a => renderBskyUserCard(a)).join('');
        if (append) feedContainer.insertAdjacentHTML('beforeend', html);
        else feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No users found for "${escapeHtml(query)}"</div>`;
      } else if (currentSearchType === 'feeds') {
        const data = await searchBskyFeeds(query, bskyCursor);
        bskyCursor = data.cursor || null;
        hasMore = !!bskyCursor;
        const html = (data.feeds || []).map(f => renderFeedCard(f)).join('');
        if (append) feedContainer.insertAdjacentHTML('beforeend', html);
        else feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">No feeds found for "${escapeHtml(query)}"</div>`;
      }
      attachAllListeners();
      initHlsVideos();
    } catch {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">Search failed</div>`;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  // ============================================================
  // INTERACTIONS
  // ============================================================
  function attachAllListeners() {
    // Bluesky likes
    document.querySelectorAll('.bsky-like-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!bskySession?.accessJwt) return;
        const uri = btn.dataset.uri;
        const cid = btn.dataset.cid;
        const countEl = btn.querySelector('.like-count');
        const count = parseInt(countEl.textContent) || 0;
        if (myLikes[uri]) {
          // Unlike
          btn.classList.remove('text-red-400');
          btn.innerHTML = `${ICON.heart} <span class="like-count">${Math.max(0, count - 1)}</span>`;
          try { await unlikeBskyPost(uri); } catch { btn.classList.add('text-red-400'); btn.innerHTML = `${ICON.heartFill} <span class="like-count">${count}</span>`; }
        } else {
          // Like
          btn.classList.add('text-red-400');
          btn.innerHTML = `${ICON.heartFill} <span class="like-count">${count + 1}</span>`;
          try { await likeBskyPost(uri, cid); } catch { btn.classList.remove('text-red-400'); btn.innerHTML = `${ICON.heart} <span class="like-count">${count}</span>`; }
        }
      });
    });

    // Bluesky reposts with quote option
    document.querySelectorAll('.bsky-repost-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async (e) => {
        if (!bskySession?.accessJwt) return;
        e.stopPropagation();
        const uri = btn.dataset.uri;
        const cid = btn.dataset.cid;
        const author = btn.dataset.author;
        const countEl = btn.querySelector('.repost-count');
        const count = parseInt(countEl.textContent) || 0;
        
        // Remove any existing repost menu
        document.querySelectorAll('.repost-menu').forEach(m => m.remove());
        
        const menu = document.createElement('div');
        menu.className = 'repost-menu absolute bottom-full left-0 mb-1 bg-theme-card border border-theme-border rounded-lg shadow-lg z-50 text-sm overflow-hidden';
        menu.innerHTML = `
          <button class="repost-opt flex items-center gap-2 w-full text-left px-4 py-2.5 hover:bg-theme-surface-hover whitespace-nowrap">${ICON.repost} ${myReposts[uri] ? 'Undo repost' : 'Repost'}</button>
          <button class="quote-opt flex items-center gap-2 w-full text-left px-4 py-2.5 hover:bg-theme-surface-hover whitespace-nowrap">${ICON.edit} Quote Post</button>
        `;
        btn.style.position = 'relative';
        btn.appendChild(menu);
        
        menu.querySelector('.repost-opt').addEventListener('click', async (ev) => {
          ev.stopPropagation();
          menu.remove();
          if (myReposts[uri]) {
            btn.classList.remove('text-green-400');
            btn.innerHTML = `${ICON.repost} <span class="repost-count">${Math.max(0, count - 1)}</span>`;
            try { await unrepostBskyPost(uri); } catch { btn.classList.add('text-green-400'); btn.innerHTML = `${ICON.repost} <span class="repost-count">${count}</span>`; }
          } else {
            btn.classList.add('text-green-400');
            btn.innerHTML = `${ICON.repost} <span class="repost-count">${count + 1}</span>`;
            try { await repostBskyPost(uri, cid); } catch { btn.classList.remove('text-green-400'); btn.innerHTML = `${ICON.repost} <span class="repost-count">${count}</span>`; }
          }
        });
        menu.querySelector('.quote-opt').addEventListener('click', (ev) => {
          ev.stopPropagation();
          menu.remove();
          quotePost(uri, author, '');
        });
        setTimeout(() => {
          document.addEventListener('click', () => menu.remove(), { once: true });
        }, 10);
      });
    });

    // Reply button → open thread
    document.querySelectorAll('.bsky-reply-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => openThread(btn.dataset.uri));
    });

    // Bookmark button → toggle bookmark
    document.querySelectorAll('.bsky-bookmark-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        const uri = btn.dataset.uri;
        const cid = btn.dataset.cid;
        const text = btn.dataset.text;
        await togglePostBookmark(uri, cid, text);
        const isBookmarked = myBookmarks[uri];
        btn.classList.toggle('text-blue-400', isBookmarked);
        btn.innerHTML = isBookmarked ? ICON.bookmarkFill : ICON.bookmark;
      });
    });

    // Avatar click → open profile
    document.querySelectorAll('.bsky-avatar:not([data-bound])').forEach(el => {
      el.dataset.bound = '1';
      el.addEventListener('click', (e) => { e.preventDefault(); openProfile(el.dataset.handle); });
    });

    // Pirate Social likes
    document.querySelectorAll('.like-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!token) return alert('Sign in to like posts');
        const postId = btn.dataset.postId;
        const isLiked = btn.classList.contains('text-red-400');
        const method = isLiked ? 'DELETE' : 'POST';
        const res = await fetch(`${hubUrl}/api/interactions/like`, {
          method, headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId }),
        });
        const data = await res.json();
        btn.innerHTML = `${data.liked ? ICON.heartFill : ICON.heart} ${data.count}`;
        btn.classList.toggle('text-red-400', data.liked);
      });
    });

    // Pirate Social follows
    document.querySelectorAll('.follow-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!token) return;
        const userId = btn.dataset.userId;
        const res = await fetch(`${hubUrl}/api/interactions/follow`, {
          method: 'POST', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId }),
        });
        const data = await res.json();
        btn.textContent = data.following ? 'Following' : 'Follow';
      });
    });

    // Share buttons
    document.querySelectorAll('.share-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => openShareModal(btn.dataset.url, btn.dataset.title));
    });

    // Feed cards — click to load that feed posts
    document.querySelectorAll('.feed-card:not([data-bound])').forEach(card => {
      card.dataset.bound = '1';
      card.addEventListener('click', (e) => {
        if (e.target.closest('.feed-sub-btn')) return; // Don't navigate when clicking subscribe
        const uri = card.dataset.feedUri;
        const name = card.dataset.feedName;
        if (uri) loadCustomFeedView(uri, name);
      });
    });

    // Feed subscribe/unsubscribe buttons
    document.querySelectorAll('.feed-sub-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const uri = btn.dataset.feedUri;
        const name = btn.dataset.feedName;
        const avatar = btn.dataset.feedAvatar;
        if (isSubscribed(uri)) {
          unsubscribeFeed(uri);
          btn.textContent = '+ Add';
          btn.className = btn.className.replace(/bg-red-500\/20 text-red-400 hover:bg-red-500\/30/, 'bg-theme-primary/20 text-theme-primary hover:bg-theme-primary/30');
        } else {
          subscribeFeed(uri, name, avatar);
          btn.textContent = '− Remove';
          btn.className = btn.className.replace(/bg-theme-primary\/20 text-theme-primary hover:bg-theme-primary\/30/, 'bg-red-500/20 text-red-400 hover:bg-red-500/30');
        }
      });
    });

    // Squad add-from-post button
    document.querySelectorAll('.bsky-squad-btn:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        if (onlineMode ? !bskySession?.accessJwt : !token) return alert('Connect Bluesky to manage squads');
        if (onlineMode) return alert('Squads require a PirateSocial node connection. Visit piratesocial.app to get started.');
        const handle = btn.dataset.handle;
        // Remove any existing dropdown
        document.querySelectorAll('.squad-picker').forEach(el => el.remove());
        try {
          const res = await fetch(`${hubUrl}/api/bluesky-feed/squads`, { headers: { Authorization: `Bearer ${token}` } });
          const squads = await res.json();
          if (!squads.length) return alert('Create a squad first in the Squads tab');
          const rect = btn.getBoundingClientRect();
          const picker = document.createElement('div');
          picker.className = 'squad-picker';
          picker.style.cssText = `position:fixed;left:${rect.left}px;top:${rect.bottom + 4}px;z-index:70;background:var(--ps-card-bg, #1a1a2e);border:1px solid var(--ps-card-border, #333);border-radius:.5rem;padding:.25rem 0;min-width:10rem;box-shadow:0 4px 12px rgba(0,0,0,.4)`;
          squads.forEach(sq => {
            const item = document.createElement('button');
            item.style.cssText = 'display:block;width:100%;text-align:left;padding:.5rem .75rem;background:none;border:none;color:var(--ps-text, #e0e0e0);cursor:pointer;font-size:.8rem';
            item.textContent = sq.name;
            item.addEventListener('mouseenter', () => item.style.background = 'var(--ps-surface-hover, rgba(255,255,255,.1))');
            item.addEventListener('mouseleave', () => item.style.background = 'none');
            item.addEventListener('click', async () => {
              picker.remove();
              const addRes = await fetch(`${hubUrl}/api/bluesky-feed/squads/${sq.id}/members`, {
                method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                body: JSON.stringify({ handle }),
              });
              if (addRes.ok) { btn.style.color = 'var(--ps-accent, #22c55e)'; }
              else { const err = await addRes.json().catch(() => ({})); alert(err.error || 'Failed to add'); }
            });
            picker.appendChild(item);
          });
          document.body.appendChild(picker);
          const closePicker = (ev) => { if (!picker.contains(ev.target) && ev.target !== btn) { picker.remove(); document.removeEventListener('click', closePicker); } };
          setTimeout(() => document.addEventListener('click', closePicker), 0);
        } catch (err) { console.error('Squad picker error:', err); }
      });
    });

    // Clickable post images → lightbox
    document.querySelectorAll('.post-img:not([data-bound])').forEach(img => {
      img.dataset.bound = '1';
      img.addEventListener('click', (e) => {
        e.stopPropagation();
        // Gather sibling images in the same gallery group
        const article = img.closest('article');
        const siblings = article ? [...article.querySelectorAll('.post-img')] : [img];
        const images = siblings.map(el => ({ src: el.dataset.full || el.src, alt: el.dataset.alt || el.alt || '' }));
        const idx = siblings.indexOf(img);
        openLightbox(images, idx >= 0 ? idx : 0);
      });
    });
  }

  // ============================================================
  // SHARE MODAL
  // ============================================================
  const shareOverlay = document.createElement('div');
  shareOverlay.id = 'share-modal-overlay';
  shareOverlay.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:60;justify-content:center;align-items:center';
  shareOverlay.innerHTML = `
    <div id="share-modal" style="background:var(--ps-card-bg);border:1px solid var(--ps-card-border);border-radius:.75rem;padding:1.5rem;width:20rem;max-width:90vw">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
        <h3 style="font-weight:600;font-size:1rem">Share</h3>
        <button id="share-close" style="color:var(--ps-text-muted);font-size:1.25rem;cursor:pointer;background:none;border:none">✕</button>
      </div>
      <div id="share-links" style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem"></div>
    </div>`;
  document.body.appendChild(shareOverlay);
  shareOverlay.addEventListener('click', (e) => { if (e.target === shareOverlay) shareOverlay.style.display = 'none'; });
  document.getElementById('share-close').addEventListener('click', () => shareOverlay.style.display = 'none');

  // ============================================================
  // IMAGE LIGHTBOX
  // ============================================================
  const lightbox = document.createElement('div');
  lightbox.id = 'img-lightbox';
  lightbox.style.cssText = 'display:none;position:fixed;inset:0;z-index:80;background:rgba(0,0,0,.92);justify-content:center;align-items:center;cursor:zoom-out';
  lightbox.innerHTML = `
    <button style="position:absolute;top:1rem;right:1rem;background:none;border:none;color:#fff;font-size:1.75rem;cursor:pointer;opacity:.8;z-index:2;line-height:1" aria-label="Close" data-lb-close>✕</button>
    <button style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.15);color:#fff;border:none;font-size:2.5rem;padding:.1rem .7rem;border-radius:.5rem;cursor:pointer;opacity:.8;z-index:2;line-height:1" aria-label="Previous" data-lb-prev>‹</button>
    <img src="" alt="" style="max-width:95vw;max-height:95vh;object-fit:contain;border-radius:.25rem" />
    <button style="position:absolute;right:1rem;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.15);color:#fff;border:none;font-size:2.5rem;padding:.1rem .7rem;border-radius:.5rem;cursor:pointer;opacity:.8;z-index:2;line-height:1" aria-label="Next" data-lb-next>›</button>
    <div style="position:absolute;bottom:1rem;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.7);font-size:.8rem" data-lb-counter></div>`;
  document.body.appendChild(lightbox);

  let lbImages = [];
  let lbIndex = 0;

  function openLightbox(images, startIndex) {
    lbImages = images;
    lbIndex = startIndex || 0;
    updateLightbox();
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function updateLightbox() {
    const img = lightbox.querySelector('img');
    img.src = lbImages[lbIndex].src;
    img.alt = lbImages[lbIndex].alt || '';
    const counter = lightbox.querySelector('[data-lb-counter]');
    counter.textContent = lbImages.length > 1 ? `${lbIndex + 1} / ${lbImages.length}` : '';
    lightbox.querySelector('[data-lb-prev]').style.display = lbImages.length > 1 ? '' : 'none';
    lightbox.querySelector('[data-lb-next]').style.display = lbImages.length > 1 ? '' : 'none';
  }

  function closeLightbox() {
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
  }

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  lightbox.querySelector('[data-lb-close]').addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });
  lightbox.querySelector('[data-lb-prev]').addEventListener('click', (e) => { e.stopPropagation(); lbIndex = (lbIndex - 1 + lbImages.length) % lbImages.length; updateLightbox(); });
  lightbox.querySelector('[data-lb-next]').addEventListener('click', (e) => { e.stopPropagation(); lbIndex = (lbIndex + 1) % lbImages.length; updateLightbox(); });
  document.addEventListener('keydown', (e) => {
    if (lightbox.style.display !== 'flex') return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') { lbIndex = (lbIndex - 1 + lbImages.length) % lbImages.length; updateLightbox(); }
    if (e.key === 'ArrowRight') { lbIndex = (lbIndex + 1) % lbImages.length; updateLightbox(); }
  });

  function openShareModal(url, title) {
    const enc = encodeURIComponent;
    const links = [
      { label: '𝕏 Twitter', href: `https://twitter.com/intent/tweet?text=${enc(title)}&url=${enc(url)}` },
      { label: '📘 Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}` },
      { label: '💼 LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}` },
      { label: '📌 Pinterest', href: `https://pinterest.com/pin/create/button/?url=${enc(url)}&description=${enc(title)}` },
      { label: '🔗 Reddit', href: `https://www.reddit.com/submit?url=${enc(url)}&title=${enc(title)}` },
      { label: '📧 Email', href: `mailto:?subject=${enc(title)}&body=${enc(url)}` },
    ];
    const linksHtml = links.map(l =>
      `<a href="${l.href}" target="_blank" rel="noopener noreferrer" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:var(--ps-input-bg);color:var(--ps-text);font-size:.875rem;text-decoration:none;transition:background .15s" onmouseover="this.style.background='var(--ps-surface-hover)'" onmouseout="this.style.background='var(--ps-input-bg)'">${l.label}</a>`
    ).join('');
    const copyBtn = `<button id="share-copy" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:var(--ps-input-bg);color:var(--ps-text);font-size:.875rem;border:none;cursor:pointer;transition:background .15s;grid-column:span 2">📋 Copy Link</button>`;
    document.getElementById('share-links').innerHTML = linksHtml + copyBtn;
    document.getElementById('share-copy').addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(url); document.getElementById('share-copy').textContent = '✓ Copied!'; setTimeout(() => document.getElementById('share-copy').textContent = '📋 Copy Link', 2000); } catch {}
    });
    shareOverlay.style.display = 'flex';
  }

  // ============================================================
  // HLS VIDEO INIT
  // ============================================================
  function initHlsVideos() {
    document.querySelectorAll('video[data-hls]').forEach(video => {
      if (video._hlsInit) return;
      video._hlsInit = true;
      const src = video.dataset.hls;
      if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = src;
      } else if (typeof Hls !== 'undefined' && Hls.isSupported()) {
        const hls = new Hls();
        hls.loadSource(src);
        hls.attachMedia(video);
      }
    });
    observeVideos();
    initYTPlaceholders();
    initVideoHeartBtns();
  }

  // ============================================================
  // VIDEO MINI-PLAYER (scroll-away → floating PiP)
  // ============================================================
  let miniPlayerEl = null;
  let miniPlayerSource = null; // the original container
  let miniPlayerDrag = { active: false, offsetX: 0, offsetY: 0 };

  function createMiniPlayer() {
    if (miniPlayerEl) return;
    miniPlayerEl = document.createElement('div');
    miniPlayerEl.id = 'mini-player';
    const savedX = socialSettings.miniPlayerX;
    const savedY = socialSettings.miniPlayerY;
    const defaultRight = 16;
    const defaultBottom = 16;
    miniPlayerEl.style.cssText = `position:fixed;z-index:9999;width:320px;border-radius:.5rem;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.5);border:2px solid var(--ps-card-border,#333);background:#000;transition:none;${
      savedX != null && savedY != null
        ? `left:${Math.min(savedX, window.innerWidth - 340)}px;top:${Math.min(savedY, window.innerHeight - 200)}px`
        : `right:${defaultRight}px;bottom:${defaultBottom}px`
    }`;

    // Drag handle bar at top
    const dragBar = document.createElement('div');
    dragBar.style.cssText = 'height:28px;background:rgba(0,0,0,.8);display:flex;align-items:center;justify-content:space-between;padding:0 6px;cursor:grab;user-select:none';
    // Back-to-post button
    const backBtn = document.createElement('button');
    backBtn.innerHTML = '↩';
    backBtn.title = 'Scroll to post';
    backBtn.style.cssText = 'background:none;color:#fff;border:none;font-size:14px;cursor:pointer;padding:0 4px;line-height:1';
    backBtn.addEventListener('click', (e) => { e.stopPropagation(); returnToPost(); });
    dragBar.appendChild(backBtn);
    // Drag indicator dots
    const dots = document.createElement('span');
    dots.textContent = '⠿⠿⠿';
    dots.style.cssText = 'color:rgba(255,255,255,.4);font-size:10px;letter-spacing:2px';
    dragBar.appendChild(dots);
    // Close button
    const closeBtn = document.createElement('button');
    closeBtn.innerHTML = '\u2715';
    closeBtn.style.cssText = 'background:none;color:#fff;border:none;font-size:14px;cursor:pointer;padding:0 4px;line-height:1';
    closeBtn.addEventListener('click', (e) => { e.stopPropagation(); closeMiniPlayer(); });
    dragBar.appendChild(closeBtn);
    miniPlayerEl.appendChild(dragBar);

    // Media container
    const mediaWrap = document.createElement('div');
    mediaWrap.style.cssText = 'aspect-ratio:16/9;width:100%';
    mediaWrap.id = 'mini-player-media';
    miniPlayerEl.appendChild(mediaWrap);

    // Drag — only from the drag bar
    dragBar.addEventListener('mousedown', startDrag);
    dragBar.addEventListener('touchstart', startDrag, { passive: false });
    document.addEventListener('mousemove', onDrag);
    document.addEventListener('touchmove', onDrag, { passive: false });
    document.addEventListener('mouseup', endDrag);
    document.addEventListener('touchend', endDrag);

    document.body.appendChild(miniPlayerEl);
  }

  function startDrag(e) {
    if (e.target.tagName === 'BUTTON') return;
    miniPlayerDrag.active = true;
    if (miniPlayerEl) miniPlayerEl.style.cursor = 'grabbing';
    const rect = miniPlayerEl.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    miniPlayerDrag.offsetX = clientX - rect.left;
    miniPlayerDrag.offsetY = clientY - rect.top;
    // Remove right/bottom positioning, switch to left/top
    miniPlayerEl.style.right = '';
    miniPlayerEl.style.bottom = '';
    if (e.cancelable) e.preventDefault();
  }

  function onDrag(e) {
    if (!miniPlayerDrag.active) return;
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    const x = Math.max(0, Math.min(clientX - miniPlayerDrag.offsetX, window.innerWidth - 340));
    const y = Math.max(0, Math.min(clientY - miniPlayerDrag.offsetY, window.innerHeight - 200));
    miniPlayerEl.style.left = x + 'px';
    miniPlayerEl.style.top = y + 'px';
    if (e.cancelable) e.preventDefault();
  }

  function endDrag() {
    if (!miniPlayerDrag.active) return;
    miniPlayerDrag.active = false;
    miniPlayerEl.style.cursor = 'grab';
    // Save position
    socialSettings.miniPlayerX = parseInt(miniPlayerEl.style.left);
    socialSettings.miniPlayerY = parseInt(miniPlayerEl.style.top);
    saveSocialSettings();
  }

  function closeMiniPlayer() {
    if (!miniPlayerEl) return;
    const mediaWrap = document.getElementById('mini-player-media');
    const isYT = miniPlayerSource && ytActiveContainer === miniPlayerSource;

    if (isYT) {
      // YouTube: don't move iframe — just pause and reposition wrapper back, then hide
      pauseYTPlayer();
      if (ytSharedIframe) ytSharedIframe._userActivated = false;
      hideYTWrapper();
      if (ytWrapper) ytWrapper._miniPlayerMode = false;
      miniPlayerSource.style.display = '';
    } else {
      // HLS/native video: move content back to original container
      const content = mediaWrap?.querySelector('video');
      if (content) {
        content.pause();
        content._wasPlaying = false;
        if (miniPlayerSource) {
          miniPlayerSource.innerHTML = '';
          miniPlayerSource.appendChild(content);
          content.style.cssText = 'width:100%;height:100%';
          content.classList.add('w-full', 'h-full');
          miniPlayerSource.style.display = '';
        }
      }
    }

    miniPlayerEl.remove();
    miniPlayerEl = null;
    miniPlayerSource = null;
  }

  function returnToPost() {
    if (miniPlayerSource) {
      const source = miniPlayerSource;
      closeMiniPlayer();
      source.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  function activateMiniPlayer(mediaContainer) {
    if (!socialSettings.miniPlayerEnabled) return;
    const isYT = mediaContainer === ytActiveContainer;
    const content = isYT ? ytSharedIframe : mediaContainer.querySelector('video');
    if (!content) return;
    // For native videos, only mini-player if playing
    if (!isYT && content.tagName === 'VIDEO' && content.paused) return;

    createMiniPlayer();
    miniPlayerSource = mediaContainer;

    if (isYT) {
      // YouTube: reposition the wrapper to the mini-player media area instead of moving iframe
      const mediaWrap = document.getElementById('mini-player-media');
      ytStopTracking(); // stop following the container
      ytWrapper._miniPlayerMode = true;
      // Position wrapper inside the mini-player by tracking mini-player-media
      function updateMiniPos() {
        if (!miniPlayerEl || !ytWrapper._miniPlayerMode) return;
        const rect = mediaWrap.getBoundingClientRect();
        ytWrapper.style.left = rect.left + 'px';
        ytWrapper.style.top = rect.top + 'px';
        ytWrapper.style.width = rect.width + 'px';
        ytWrapper.style.height = rect.height + 'px';
        ytWrapper.style.opacity = '1';
        ytWrapper.style.pointerEvents = 'auto';
        ytWrapper.style.zIndex = '10000';
        ytPositionRAF = requestAnimationFrame(updateMiniPos);
      }
      ytPositionRAF = requestAnimationFrame(updateMiniPos);
      mediaContainer.style.display = 'none';
    } else {
      // Native video: move into mini-player as before
      const mediaWrap = document.getElementById('mini-player-media');
      content.style.cssText = 'width:100%;height:100%;border:none';
      content.className = '';
      mediaWrap.appendChild(content);
      mediaContainer.style.display = 'none';
    }
  }

  function deactivateMiniPlayer(mediaContainer) {
    if (miniPlayerSource !== mediaContainer) return;
    const isYT = mediaContainer === ytActiveContainer;

    if (isYT && ytWrapper) {
      // YouTube: reposition wrapper back over the inline container
      ytWrapper._miniPlayerMode = false;
      ytWrapper.style.zIndex = '40';
      mediaContainer.style.display = '';
      ytPositionOver(mediaContainer);
      ytStartTracking();
    }

    // Remove mini-player chrome (but don't pause/move content for YT)
    if (miniPlayerEl) {
      if (!isYT) {
        // For native video, move content back
        const mediaWrap = document.getElementById('mini-player-media');
        const content = mediaWrap?.querySelector('video');
        if (content && miniPlayerSource) {
          miniPlayerSource.innerHTML = '';
          miniPlayerSource.appendChild(content);
          content.style.cssText = 'width:100%;height:100%';
          content.classList.add('w-full', 'h-full');
          miniPlayerSource.style.display = '';
        }
      }
      miniPlayerEl.remove();
      miniPlayerEl = null;
    }
    miniPlayerSource = null;
  }

  // Observe video/iframe containers for scroll-away
  const miniPlayerObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const container = entry.target;
      if (!entry.isIntersecting) {
        // Scrolled out of view
        const isYT = container === ytActiveContainer;
        const content = isYT ? ytSharedIframe : container.querySelector('video');
        if (!content && !isYT) return;

        // If mini-player is disabled, pause/stop when scrolled away
        if (!socialSettings.miniPlayerEnabled) {
          if (!isYT && content?.tagName === 'VIDEO' && !content.paused) content.pause();
          if (isYT && ytSharedIframe?._userActivated) {
            pauseYTPlayer();
            hideYTWrapper();
          }
          return;
        }

        // Mini-player enabled — activate if user was watching
        if (!isYT && content?.tagName === 'VIDEO' && content.paused) return;
        if (isYT && !ytSharedIframe?._userActivated) return;
        if (miniPlayerSource === container) return; // already active
        if (miniPlayerEl) closeMiniPlayer(); // close any existing
        activateMiniPlayer(container);
      } else {
        // Scrolled back into view — return to inline
        if (miniPlayerSource === container) {
          deactivateMiniPlayer(container);
        }
      }
    });
  }, { threshold: 0.15 });

  function addIframeOverlay(container, iframe) {
    container.style.position = 'relative';
    const overlay = document.createElement('div');
    overlay.style.cssText = 'position:absolute;inset:0;z-index:5;cursor:pointer';
    overlay.addEventListener('click', () => {
      iframe._userActivated = true;
      pauseAllMedia(iframe);
      overlay.remove();
    });
    container.appendChild(overlay);
  }

  function pauseAllMedia(except) {
    document.querySelectorAll('.aspect-video video').forEach(v => {
      if (v !== except && !v.paused) v.pause();
    });
    // Pause the shared YT player if it's not the exception
    if (ytSharedIframe && ytSharedIframe !== except && ytSharedIframe._userActivated) {
      pauseYTPlayer();
    }
  }

  function observeVideos() {
    document.querySelectorAll('.aspect-video').forEach(container => {
      if (container._miniPlayerObserved) return;
      // Skip the dedicated top player on the YouTube tab
      if (container.id === 'yt-top-player') return;
      container._miniPlayerObserved = true;
      miniPlayerObserver.observe(container);
      // For HLS videos, track play/pause and pause others on play
      const video = container.querySelector('video');
      if (video && !video._playListenerAdded) {
        video._playListenerAdded = true;
        video.addEventListener('play', () => { video._wasPlaying = true; pauseAllMedia(video); });
        video.addEventListener('pause', () => { video._wasPlaying = false; });
      }
    });
  }

  // ============================================================
  // SINGLE SHARED YOUTUBE PLAYER — never move the iframe in the DOM
  // Moving iframes between DOM parents causes browser to reload them (= new ads).
  // Instead we keep the iframe in a permanent fixed-position wrapper and reposition
  // it visually over whichever container is active.
  //
  // IMPORTANT: Store on window.* because this script has data-astro-rerun which
  // re-executes on every navigation, resetting all let/const variables.
  // Without window.*, the iframe reference is lost and a new one is created (= ads).
  // ============================================================
  let ytSharedIframe = window.__ytSharedIframe || null;
  let ytWrapper = window.__ytWrapper || null;
  let ytActiveContainer = window.__ytActiveContainer || null;
  let ytApiReady = window.__ytApiReady || false;
  let ytPendingVideoId = window.__ytPendingVideoId || null;
  const ytOrigin = window.location.origin;
  let ytPositionRAF = window.__ytPositionRAF || null;

  function getOrCreateYTIframe() {
    if (ytSharedIframe) return ytSharedIframe;

    // Create permanent wrapper — stays in body forever
    // Starts as 1x1 invisible (NOT display:none) so YouTube autoplay works during pre-warm.
    // display:none blocks autoplay which prevents the ad slot from being consumed.
    ytWrapper = document.createElement('div');
    ytWrapper.style.cssText = 'position:fixed;z-index:-1;pointer-events:none;overflow:hidden;border-radius:0;width:1px;height:1px;opacity:0';
    document.body.appendChild(ytWrapper);

    ytSharedIframe = document.createElement('iframe');
    ytSharedIframe.setAttribute('frameborder', '0');
    ytSharedIframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
    ytSharedIframe.setAttribute('allowfullscreen', '');
    ytSharedIframe.style.cssText = 'width:100%;height:100%;border:none';
    ytWrapper.appendChild(ytSharedIframe);

    // Persist to window so data-astro-rerun doesn't lose them
    window.__ytSharedIframe = ytSharedIframe;
    window.__ytWrapper = ytWrapper;

    // Listen for YouTube player postMessage events
    window.addEventListener('message', (e) => {
      if (!ytSharedIframe) return;
      let data;
      try { data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data; } catch { return; }

      if (data.event === 'onStateChange') {
        const state = data.info;
        if (state === 1 || state === 3) {
          ytSharedIframe._userActivated = true;
          // Auto-unmute after playback starts (muted autoplay bypasses pre-roll ads)
          if (state === 1 && !ytSharedIframe._unmuted) {
            ytSharedIframe._unmuted = true;
            setTimeout(() => { ytSendCommand('unMute'); ytSendCommand('setVolume', [100]); }, 1500);
          }
        } else if (state === 2 || state === 0) {
          ytSharedIframe._userActivated = false;
        }
      }

      if (data.event === 'initialDelivery' || data.event === 'onReady') {
        ytApiReady = true;
        window.__ytApiReady = true;
        if (ytPendingVideoId) {
          const vid = ytPendingVideoId;
          ytPendingVideoId = null;
          window.__ytPendingVideoId = null;
          ytSendCommand('loadVideoById', [vid]);
        }
      }
    });

    return ytSharedIframe;
  }

  function ytSendCommand(func, args) {
    if (!ytSharedIframe?.contentWindow) return;
    try {
      ytSharedIframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func, args: args || '' }), '*');
    } catch {}
  }

  function ytHandshake() {
    if (!ytSharedIframe?.contentWindow) return;
    try {
      ytSharedIframe.contentWindow.postMessage(JSON.stringify({ event: 'listening', id: 1 }), '*');
    } catch {}
    ytSendCommand('addEventListener', ['onStateChange']);
  }

  // Position the fixed wrapper over a target element — also makes it fully visible
  function ytPositionOver(target) {
    if (!ytWrapper || !target) return;
    const rect = target.getBoundingClientRect();
    ytWrapper.style.left = rect.left + 'px';
    ytWrapper.style.top = rect.top + 'px';
    ytWrapper.style.width = rect.width + 'px';
    ytWrapper.style.height = rect.height + 'px';
    ytWrapper.style.opacity = '1';
    ytWrapper.style.zIndex = '40';
    ytWrapper.style.pointerEvents = 'auto';
  }

  // Continuously reposition over the active container (handles scroll)
  function ytStartTracking() {
    ytStopTracking();
    function update() {
      if (ytActiveContainer && ytWrapper && ytWrapper.style.opacity !== '0' && !ytWrapper._miniPlayerMode) {
        ytPositionOver(ytActiveContainer);
      }
      ytPositionRAF = requestAnimationFrame(update);
    }
    ytPositionRAF = requestAnimationFrame(update);
    window.__ytPositionRAF = ytPositionRAF;
  }

  function ytStopTracking() {
    if (ytPositionRAF) { cancelAnimationFrame(ytPositionRAF); ytPositionRAF = null; window.__ytPositionRAF = null; }
  }

  // Persistent heart button on the YouTube wrapper — stays above the iframe
  function updateWrapperHeart(videoId, title, thumbnail) {
    if (!ytWrapper) return;
    let heart = ytWrapper.querySelector('.yt-wrapper-heart');
    if (!heart) {
      heart = document.createElement('button');
      heart.className = 'yt-wrapper-heart';
      heart.style.cssText = 'position:absolute;top:8px;right:8px;z-index:50;padding:6px;border-radius:9999px;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);border:none;cursor:pointer;transition:background 0.2s,color 0.2s;color:#fff;display:flex;align-items:center;justify-content:center';
      heart.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
      heart.addEventListener('mouseenter', () => { heart.style.background = 'rgba(0,0,0,0.7)'; });
      heart.addEventListener('mouseleave', () => { heart.style.background = 'rgba(0,0,0,0.5)'; });
      heart.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleWatchlist(heart._vidId, heart._vidTitle, heart._vidThumb);
        syncWrapperHeart();
      });
      ytWrapper.appendChild(heart);
    }
    heart._vidId = videoId;
    heart._vidTitle = title || '';
    heart._vidThumb = thumbnail || `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
    heart.style.display = 'flex';
    syncWrapperHeart();
  }

  function syncWrapperHeart() {
    const heart = ytWrapper?.querySelector('.yt-wrapper-heart');
    if (!heart || !heart._vidId) return;
    const inList = isInWatchlist(heart._vidId);
    heart.querySelector('svg').setAttribute('fill', inList ? 'currentColor' : 'none');
    heart.style.color = inList ? '#ef4444' : '#fff';
  }

  function playYTVideo(container, videoId) {
    pauseAllMedia(null);
    const iframe = getOrCreateYTIframe();

    // If another container was active, restore its placeholder
    if (ytActiveContainer && ytActiveContainer !== container) {
      returnYTPlaceholder(ytActiveContainer);
    }

    // Grab heart metadata from the container before destroying innerHTML
    const heartBtn = container.querySelector('.vid-heart-btn');
    const heartTitle = heartBtn?.dataset.vidTitle || '';
    const heartThumb = heartBtn?.dataset.vidThumb || `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;

    // Save original placeholder content & hide it (wrapper overlays it)
    if (!container._ytPlaceholderHTML) {
      container._ytPlaceholderHTML = container.innerHTML;
    }
    container.innerHTML = '<div style="width:100%;aspect-ratio:16/9;background:#000"></div>';
    container.style.cursor = '';
    container.classList.remove('yt-placeholder');
    ytActiveContainer = container;

    // Position wrapper over this container
    ytWrapper._miniPlayerMode = false;
    ytWrapper.style.borderRadius = '0';
    ytPositionOver(container);
    ytStartTracking();

    // Show floating heart on the wrapper
    updateWrapperHeart(videoId, heartTitle, heartThumb);

    // Load video: first time sets src; subsequent use postMessage (no reload, no ads)
    if (!iframe._firstLoaded) {
      iframe._firstLoaded = true;
      iframe._unmuted = false;
      ytApiReady = false;
      window.__ytApiReady = false;
      ytPendingVideoId = null;
      window.__ytPendingVideoId = null;
      iframe.src = `https://www.youtube.com/embed/${videoId}?enablejsapi=1&autoplay=1&mute=1&rel=0&modestbranding=1&origin=${encodeURIComponent(ytOrigin)}`;
      iframe.addEventListener('load', () => { setTimeout(ytHandshake, 300); }, { once: true });
    } else if (ytApiReady) {
      // Mute before loading next video to bypass pre-roll ads, then auto-unmute on play
      iframe._unmuted = false;
      ytSendCommand('mute');
      ytSendCommand('loadVideoById', [videoId]);
    } else {
      ytPendingVideoId = videoId;
      window.__ytPendingVideoId = videoId;
    }

    iframe._userActivated = true;
    window.__ytActiveContainer = ytActiveContainer;

    // Observe this container for scroll-away behavior (skip dedicated top player)
    if (!container._miniPlayerObserved && container.id !== 'yt-top-player') {
      container._miniPlayerObserved = true;
      miniPlayerObserver.observe(container);
    }
  }

  function returnYTPlaceholder(container) {
    if (!container) return;
    // Restore the thumbnail placeholder
    if (container._ytPlaceholderHTML) {
      container.innerHTML = container._ytPlaceholderHTML;
      container.style.cursor = 'pointer';
      container.classList.add('yt-placeholder');
    }
    if (ytActiveContainer === container) {
      ytActiveContainer = null;
      window.__ytActiveContainer = null;
    }
  }

  function hideYTWrapper() {
    if (ytWrapper) {
      ytWrapper.style.width = '1px';
      ytWrapper.style.height = '1px';
      ytWrapper.style.opacity = '0';
      ytWrapper.style.zIndex = '-1';
      ytWrapper.style.pointerEvents = 'none';
      // Hide wrapper heart
      const wh = ytWrapper.querySelector('.yt-wrapper-heart');
      if (wh) wh.style.display = 'none';
    }
    ytStopTracking();
  }

  function pauseYTPlayer() {
    if (ytSharedIframe) {
      ytSendCommand('pauseVideo');
      ytSharedIframe._userActivated = false;
    }
  }

  function initYTPlaceholders() {
    document.querySelectorAll('.yt-placeholder:not([data-yt-bound])').forEach(container => {
      container.dataset.ytBound = '1';
      container.addEventListener('click', () => {
        const videoId = container.dataset.ytId;
        if (videoId) playYTVideo(container, videoId);
      });
    });
    // No pre-warm iframe here — creating a second YouTube embed on the page
    // interferes with the floating component's ad-free session and causes ads
    // on both players. The first video click will set iframe.src (one ad),
    // then all subsequent clicks use loadVideoById (no ads).
  }

