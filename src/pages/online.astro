      b.setAttribute('aria-selected', 'false');
      b.removeAttribute('tabindex');
    });
    currentTab = 'feeds';
    resetPagination();
    updateUI();
    loadCustomFeedView(uri, feed.name);
  });

  function resetPagination() {
    piratePage = 1;
    bskyCursor = null;
    hasMore = true;
  }

  function updateUI() {
    syncAnonymousTabVisibility();
    filterBar.classList.toggle('hidden', currentTab !== 'timeline');
    discoverPills.classList.toggle('hidden', currentTab !== 'discover');
    rssManagement.classList.toggle('hidden', currentTab !== 'rss');
    const discoverSearchBar = document.getElementById('discover-search-bar');
    if (discoverSearchBar) {
      const showSearch = !!token && currentTab === 'discover' && (currentDiscoverSub === 'people' || currentDiscoverSub === 'feeds');
      discoverSearchBar.classList.toggle('hidden', !showSearch);
      const input = document.getElementById('discover-search-input');
      if (input) input.placeholder = currentDiscoverSub === 'people' ? 'Search people...' : 'Search feeds...';
    }
    const composeBox = document.getElementById('compose-box');
    if (composeBox) composeBox.style.display = (currentTab === 'timeline' && bskySession?.accessJwt) ? '' : 'none';
    const floatingComposeTrigger = document.getElementById('floating-compose-trigger');
    // Show FAB on non-timeline tabs when logged in (timeline already has inline compose)
    if (floatingComposeTrigger) floatingComposeTrigger.classList.toggle('hidden', !bskySession?.accessJwt || currentTab === 'timeline');
    // Hide notification pills container if present from prev render
    const notifPills = document.getElementById('notif-pills');
    if (notifPills && currentTab !== 'notifications') notifPills.remove();
  }

  function loadCurrentTab() {
    if (currentTab === 'timeline') loadFeedTab();
    else if (currentTab === 'discover') loadDiscoverTab();
    else if (currentTab === 'squads') renderSquadsView();
    else if (currentTab === 'posts') loadPostsTab();
    else if (currentTab === 'youtube') loadYouTubeTab();
    else if (currentTab === 'rss') loadRSSTab();
    else if (currentTab === 'notifications') loadNotificationsTab();
  }

  function showLoggedOutSocialState() {
    clearCachedAuthState();
    activeFeedUri = null;
    activeFeedName = null;
    // Redirect off Bluesky-only tabs; everything else stays where it is
    if (['squads', 'posts', 'notifications'].includes(currentTab)) currentTab = 'timeline';
    syncAnonymousTabVisibility();
    const activeBtn = document.getElementById(`tab-${currentTab}`) || document.getElementById('tab-timeline');
    if (activeBtn) setActiveTab(activeBtn);
    updateUI();
    loadCurrentTab();
  }

  async function ensureHubAuth() {
    if (onlineMode) {
      // Online mode: Bluesky session is primary auth (no hub token required)
      if (bskySession?.accessJwt) {
        blueskyConnected = true;
        blueskyStatusLoaded = true;
        return true;
      }
      if (bskySession?.refreshJwt) {
        const refreshed = await refreshBskySession().catch(() => null);
        if (refreshed?.accessJwt) {
          blueskyConnected = true;
          blueskyStatusLoaded = true;
          return true;
        }
      }
      // No Bluesky session but may have hub token (optional node connection)
      if (token) {
        // Fall through to normal hub auth below to validate hub token
      } else {
        clearCachedAuthState();
        return false;
      }
    }
    if (!token) {
      clearCachedAuthState();
      return false;
    }
    try {
      const res = await fetchTimeout(`${hubUrl}/api/auth/me`, { headers: { Authorization: `Bearer ${token}` } }, 10000);
      if (res.ok) return true;
      if (res.status !== 401 && res.status !== 403) {
        // Don't log users out on transient backend errors.
        return true;
      }
    } catch (err) {
      console.warn('[PS] Auth check failed:', err?.message || err);
      // Network/CORS hiccups shouldn't force logout loops.
      return true;
    }

    // Definite auth failure: clear stale token to avoid dead half-logged-in UI.
    clearCachedAuthState();
    return false;
  }

