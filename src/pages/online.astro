  // --- Feeds dropdown ---
  const feedsDropdown = document.getElementById('tab-feeds');

  function populateFeedsDropdown() {
    feedsDropdown.innerHTML = '<option value="" disabled selected>Feeds</option>';
    subscribedFeeds.forEach(f => {
      const opt = document.createElement('option');
      opt.value = f.uri;
      opt.textContent = f.name || 'Untitled Feed';
      feedsDropdown.appendChild(opt);
    });
    feedsDropdown.style.display = subscribedFeeds.length ? '' : 'none';
  }
  populateFeedsDropdown();

  feedsDropdown.addEventListener('change', () => {
    const uri = feedsDropdown.value;
    const feed = subscribedFeeds.find(f => f.uri === uri);
    if (!uri || !feed) return;
    document.querySelectorAll('[id^="tab-"]:not(#tab-feeds)').forEach(b => {
      b.classList.remove('active-tab', 'bg-theme-surface-hover');
