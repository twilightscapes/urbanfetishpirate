---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/config';
import labels from '../content/labels.json';
import settings from '../content/settings.json';
const base = ''; // online mode: served from hub root, no base path
const sl = labels.social;
const navStyle = (settings as any).navStyle || 'top';
const tabBarTop = navStyle === 'float' ? 'top-0' : 'top-[41px] md:top-[57px]';
---

<BaseLayout title="Social" onlineMode={true}>
  <div class="mx-auto max-w-3xl">
    <div class={`sticky ${tabBarTop} z-30 -mx-4 px-3 py-2 md:px-4 md:py-4 mb-4 md:mb-8 flex items-center justify-center bg-theme-bg/95 backdrop-blur supports-[backdrop-filter]:bg-theme-bg/80 border-b border-theme-border`}>
      <div class="flex gap-1 md:gap-2 flex-wrap justify-center" role="tablist" aria-label="Social sections">
      
        <button id="tab-timeline" role="tab" aria-selected="true" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition active-tab" aria-current="true" tabindex="-1">
          {sl.tabTimeline}
        </button>
        <button id="tab-discover" role="tab" aria-selected="false" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabDiscover}
        </button>
        <button id="tab-squads" role="tab" aria-selected="false" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabSquads}
        </button>
        <button id="tab-posts" role="tab" aria-selected="false" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          Posts
        </button>
        <button id="tab-youtube" role="tab" aria-selected="false" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabYouTube}
        </button>
        <button id="tab-rss" role="tab" aria-selected="false" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          RSS
        </button>
          <select id="tab-feeds" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition cursor-pointer" style="appearance:none;-webkit-appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23999%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>');background-repeat:no-repeat;background-position:right 6px center;padding-right:20px;width:auto;max-width:7rem">
          <option value="" disabled selected>Feeds</option>
        </select>
      </div>
    </div>

    <!-- Filter pills (shown for Feed tab) -->
    <div id="feed-filters" class="flex gap-1 flex-wrap mb-4">
      <button class="filter-pill active-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="all" aria-current="true" tabindex="-1">All</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="no-reposts">No Reposts</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="images">Images</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="videos">Videos</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="youtube">YouTube</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="text">Text Only</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="links">Links</button>
      <button class="filter-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-filter="pirate">Pirate RSS</button>
      <button id="saved-posts-btn" class="filter-pill rounded bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition border border-theme-border flex items-center gap-1" data-filter="bookmarks"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg> Saved</button>
    </div>

    <!-- Discover sub-tabs (shown for Discover tab) -->
    <div id="discover-pills" class="hidden flex gap-1.5 flex-wrap mb-4">
      <button class="discover-pill active-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-sub="trending" aria-current="true" tabindex="-1">Trending</button>
      <button class="discover-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-sub="people">People</button>
      <button class="discover-pill rounded-full bg-theme-input-bg px-3 py-1 text-xs hover:bg-theme-surface-hover transition" data-sub="feeds">Custom Feeds</button>
    </div>

    <!-- Discover search bar -->
    <div id="discover-search-bar" class="hidden mb-4">
      <div class="flex gap-2">
        <input type="text" id="discover-search-input" placeholder="Search..."
          class="flex-1 rounded bg-theme-input-bg border border-theme-input-border px-3 py-2 text-sm focus:outline-none focus:border-theme-primary" />
        <button id="discover-search-btn" class="rounded bg-theme-primary px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">Search</button>
      </div>
    </div>

    <!-- Search bar (HIDDEN) -->
    <div id="search-bar" class="hidden mb-4"></div>

    <!-- RSS management section (shown for RSS tab) -->
    <div id="rss-management" class="hidden mb-4 space-y-4"></div>

    <!-- Post composer (shown when logged in to Bluesky) -->
    <div id="compose-box" style="display:none" class="mb-6 rounded-lg border border-theme-card-border bg-theme-card p-4">
      <textarea id="compose-input" rows="3" placeholder="What's Up?" style="width:100%;background:var(--ps-input-bg,#1a1a2e);border:1px solid var(--ps-input-border,#333);border-radius:.5rem;padding:.75rem;color:var(--ps-text,#e0e0e0);font-size:.875rem;resize:vertical;outline:none" maxlength="300"></textarea>
      <!-- Attached media thumbnails -->
      <div id="compose-images" class="hidden flex gap-2 flex-wrap mt-2"></div>
      <div id="compose-link-preview"></div>
      <!-- Compose toolbar -->
      <div class="flex items-center justify-between mt-2 pt-2 border-t border-theme-border">
        <div class="flex items-center gap-0.5">
          <button id="compose-media-btn" type="button" title="Add photo/video" class="p-1.5 rounded text-theme-muted hover:text-theme-text hover:bg-theme-surface-hover transition">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </button>
          <input id="compose-media-input" type="file" accept="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/quicktime" multiple hidden>
          <button id="compose-emoji-btn" type="button" title="Emoji" class="p-1.5 rounded text-theme-muted hover:text-theme-text hover:bg-theme-surface-hover transition">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </button>
          <button id="compose-tags-btn" type="button" title="Tag groups" class="p-1.5 rounded text-theme-muted hover:text-theme-text hover:bg-theme-surface-hover transition">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          </button>
        </div>
        <div class="flex items-center gap-2">
          <span id="compose-count" class="text-xs text-theme-faint">0/300</span>
          <div id="delay-controls" class="flex items-center gap-1">
            <select id="post-delay" class="rounded bg-theme-input-bg border border-theme-input-border px-2 py-1 text-xs focus:outline-none focus:border-theme-primary text-theme-text" style="min-width:5rem">
              <option value="0">Post Now</option>
              <option value="60" selected>1 min</option>
              <option value="180">3 min</option>
              <option value="300">5 min</option>
              <option value="custom">Schedule...</option>
            </select>
            <input id="schedule-datetime" type="datetime-local" class="hidden rounded bg-theme-input-bg border border-theme-input-border px-2 py-1 text-xs focus:outline-none focus:border-theme-primary" />
          </div>
          <button id="compose-send" style="background:var(--ps-accent,#3b82f6);color:#fff;border:none;border-radius:.375rem;padding:.375rem 1rem;font-size:.875rem;cursor:pointer;opacity:.5" disabled>Post</button>
        </div>
      </div>
      <!-- Emoji picker panel -->
      <div id="compose-emoji-panel" class="hidden mt-2 rounded-lg border border-theme-border bg-theme-surface p-2" style="max-height:12rem;overflow-y:auto"></div>
      <div id="scheduled-posts-list" class="mt-3 hidden border-t border-theme-border pt-3"></div>
    </div>

    <!-- Pending delayed posts (typo-catch mode) -->
    <div id="pending-posts" class="mb-4 space-y-2"></div>

    <button id="floating-compose-trigger" type="button" class="hidden fixed bottom-24 right-6 z-40 rounded-full shadow-lg transition-all duration-200 w-14 h-14 flex items-center justify-center" style="background:#1185fe;color:#fff" title="New Post">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
    </button>

    <!-- Floating compose shell — the compose-box gets moved here when FAB is tapped -->
    <div id="floating-compose-shell" class="fixed inset-x-0 bottom-0 z-50 translate-y-full transition-transform duration-300 ease-in-out" style="pointer-events:none">
      <div class="max-w-2xl mx-auto px-4 pb-20" style="pointer-events:auto">
        <div class="rounded-t-xl border border-theme-card-border bg-theme-card shadow-2xl overflow-hidden">
          <div class="flex items-center justify-between px-4 pt-3 pb-1">
            <span class="text-xs font-medium text-theme-muted">New Post</span>
            <button id="floating-compose-close" class="text-theme-faint hover:text-theme-text text-lg leading-none">&times;</button>
          </div>
          <div id="floating-compose-slot" class="px-4 pb-4"></div>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div id="feed-container" class="space-y-6">
      <div class="text-center text-theme-faint py-12">
        <div class="loader-spinner mx-auto h-6 w-6 border-2 border-theme-border border-t-theme-muted rounded-full animate-spin"></div>
        <p class="mt-2">Loading...</p>
      </div>
    </div>

    <!-- Scroll sentinel -->
    <div id="scroll-sentinel" class="mt-8 flex justify-center py-4 hidden">
      <div class="loader-spinner h-6 w-6 border-2 border-theme-border border-t-theme-muted rounded-full animate-spin"></div>
    </div>
  </div>

  <!-- Thread/Profile slide-over panel -->
  <div id="slide-panel" class="fixed inset-0 z-50 hidden">
    <div id="slide-backdrop" class="absolute inset-0 bg-black/60"></div>
    <div id="slide-content" class="absolute right-0 top-0 h-full w-full max-w-lg bg-theme-bg border-l border-theme-border overflow-y-auto" style="transform:translateX(100%);transition:transform .3s ease">
      <div class="sticky top-0 bg-theme-bg/95 backdrop-blur border-b border-theme-border p-4 flex items-center justify-between z-10">
        <h2 id="slide-title" class="font-semibold text-sm"></h2>
        <button id="slide-close" class="text-theme-muted hover:text-theme-text text-xl">✕</button>
      </div>
      <div id="slide-body" class="p-4 space-y-4"></div>
    </div>
  </div>

  <!-- Tag Groups Modal -->
  <div id="tag-groups-modal" class="fixed inset-0 z-[60] hidden items-center justify-center">
    <div id="tag-groups-backdrop" class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 w-full max-w-sm mx-4 rounded-xl border border-theme-border bg-theme-surface shadow-2xl overflow-hidden">
      <div class="flex items-center justify-between px-4 py-3 border-b border-theme-border">
        <h3 class="font-semibold text-sm text-theme-text">Tag Groups</h3>
        <button id="tag-groups-close" class="text-theme-faint hover:text-theme-text text-lg leading-none">✕</button>
      </div>
      <div id="tag-groups-list" class="p-3 space-y-2" style="max-height:16rem;overflow-y:auto"></div>
      <div class="px-3 pb-3 pt-3 border-t border-theme-border space-y-2">
        <input id="tag-group-name" type="text" placeholder="Group name (e.g. Landscape)" class="w-full rounded bg-theme-input-bg border border-theme-input-border px-2 py-1.5 text-xs focus:outline-none focus:border-theme-primary text-theme-text" />
        <textarea id="tag-group-tags" rows="2" placeholder="#tag1 #tag2 @handle.bsky.social" class="w-full rounded bg-theme-input-bg border border-theme-input-border px-2 py-1.5 text-xs focus:outline-none focus:border-theme-primary text-theme-text resize-none"></textarea>
        <div class="flex gap-2">
          <button id="tag-group-save" type="button" style="background:var(--ps-accent,#3b82f6);color:#fff;border:none;border-radius:.375rem;padding:.35rem .75rem;font-size:.75rem;cursor:pointer;flex:1">Save Group</button>
          <button id="tag-group-cancel" type="button" class="hidden rounded border border-theme-border text-xs px-3 py-1 text-theme-muted hover:bg-theme-surface-hover transition">Cancel</button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/hls.js@latest/dist/hls.min.js"></script>
<script is:inline define:vars={{ hubUrl: 'https://piratesocial.app', onlineMode: true, L: labels.social, FL: labels.feeds, psBase: '/online' }} data-astro-rerun>
  const authStorageKey = (key) => `${key}:${psBase || '/'}`;
  // ============================================================
  // STATE
  // ============================================================
  let token = localStorage.getItem(authStorageKey('ps_token'));
  const feedContainer = document.getElementById('feed-container');
  const scrollSentinel = document.getElementById('scroll-sentinel');
  const filterBar = document.getElementById('feed-filters');
  const discoverPills = document.getElementById('discover-pills');
  const rssManagement = document.getElementById('rss-management');

  let currentTab = 'timeline';
  let currentFilter = 'all';
  let currentDiscoverSub = 'trending';
  let currentSearchType = 'posts';
  let bskyCursor = null;
  let piratePage = 1;
  let isLoading = false;
  let hasMore = true;
  let bskySession = null;
  let blueskyConnected = false;
  let blueskyStatusLoaded = false;
  let myHandle = null;
  let myDid = null;
  let myAvatar = null;
  let myDisplayName = null;
  // Track own likes/reposts/bookmarks for optimistic UI
  let myLikes = {};    // uri -> likeUri
  let myReposts = {};  // uri -> repostUri
  let myBookmarks = {};  // uri -> true (bookmarked)

  // Notification state
  let notifCursor = null;
  let notifSub = 'all'; // 'all', 'mentions', 'nudges'

  // Squad member lookup for highlighting (handle -> color)
  let squadMemberHandles = new Map();

  // Video state
  let youtubeChannels = [];
  let videoWatchlist = [];
  let showYouTubeInFeed = true;

  // Load watchlist from localStorage
  try { const wl = JSON.parse(localStorage.getItem('ps_video_watchlist') || localStorage.getItem('ps_yt_watchlist')); if (Array.isArray(wl)) videoWatchlist = wl; } catch {}
  function saveWatchlist() { localStorage.setItem('ps_video_watchlist', JSON.stringify(videoWatchlist)); }
  function isInWatchlist(videoId) { return videoWatchlist.some(v => v.videoId === videoId); }
  function videoHeartBtn(videoId, title, thumbnail, extraAttrs) {
    const filled = isInWatchlist(videoId);
    return `<button class="vid-heart-btn absolute top-2 right-2 z-20 p-1.5 rounded-full bg-black/50 backdrop-blur-sm hover:bg-black/70 transition ${filled ? 'text-red-500' : 'text-white'}" style="z-index:20" data-vid-id="${escapeHtml(videoId)}" data-vid-title="${escapeHtml(title || '')}" data-vid-thumb="${escapeHtml(thumbnail || '')}" ${extraAttrs || ''}><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="${filled ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>`;
  }
  function initVideoHeartBtns() {
    document.querySelectorAll('.vid-heart-btn:not([data-heart-bound])').forEach(btn => {
      btn.dataset.heartBound = '1';
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        const extra = {};
        if (btn.dataset.vidType) extra.type = btn.dataset.vidType;
        if (btn.dataset.vidHls) extra.hlsUrl = btn.dataset.vidHls;
        toggleWatchlist(btn.dataset.vidId, btn.dataset.vidTitle, btn.dataset.vidThumb, extra);
      });
    });
  }
  function toggleWatchlist(videoId, title, thumbnail, extra) {
    if (isInWatchlist(videoId)) {
      videoWatchlist = videoWatchlist.filter(v => v.videoId !== videoId);
    } else {
      const item = { videoId, title: title || '', thumbnail: thumbnail || '', addedAt: Date.now(), type: extra?.type || 'youtube' };
      if (extra?.hlsUrl) item.hlsUrl = extra.hlsUrl;
      if (!item.thumbnail && item.type === 'youtube') item.thumbnail = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
      videoWatchlist.push(item);
    }
    saveWatchlist();
    // Update all heart icons for this video
    const inList = isInWatchlist(videoId);
    document.querySelectorAll(`.vid-heart-btn[data-vid-id="${CSS.escape(videoId)}"]`).forEach(btn => {
      btn.querySelector('svg').setAttribute('fill', inList ? 'currentColor' : 'none');
      btn.classList.toggle('text-red-500', inList);
      btn.classList.toggle('text-white', !inList);
    });
    // Also update the wrapper heart if it matches
    if (typeof syncWrapperHeart === 'function') syncWrapperHeart();
    // Re-render watchlist if Video tab is active
    if (currentTab === 'youtube') { const wlEl = document.getElementById('yt-watchlist-content'); if (wlEl) renderWatchlistItems(); }
  }

  // Squad state
  let allSquads = [];
  let squadsInitialized = false;

  // Social settings (persisted in localStorage)
  const defaultSocialSettings = { squadHighlight: true, squadBorderColor: '#eab308', miniPlayerEnabled: true, miniPlayerX: null, miniPlayerY: null };
  let socialSettings = { ...defaultSocialSettings };
  try { const s = JSON.parse(localStorage.getItem('ps_social_settings')); if (s) socialSettings = { ...defaultSocialSettings, ...s }; } catch {}
  function saveSocialSettings() { localStorage.setItem('ps_social_settings', JSON.stringify(socialSettings)); }

  // Subscribed custom feeds (persisted in localStorage)
  let subscribedFeeds = []; // [{uri, name, avatar}]
  try { const sf = JSON.parse(localStorage.getItem('ps_subscribed_feeds')); if (Array.isArray(sf)) subscribedFeeds = sf; } catch {}
  function saveSubscribedFeeds() { localStorage.setItem('ps_subscribed_feeds', JSON.stringify(subscribedFeeds)); }
  function isSubscribed(feedUri) { return subscribedFeeds.some(f => f.uri === feedUri); }
  function subscribeFeed(uri, name, avatar) {
    if (!isSubscribed(uri)) { subscribedFeeds.push({ uri, name, avatar }); saveSubscribedFeeds(); populateFeedsDropdown(); }
  }
  function unsubscribeFeed(uri) {
    subscribedFeeds = subscribedFeeds.filter(f => f.uri !== uri);
    saveSubscribedFeeds();
    populateFeedsDropdown();
  }

  // ============================================================
  // LOADING SPINNER
  // ============================================================
  const SPINNER = `<div class="flex justify-center py-8"><div class="loader-spinner h-6 w-6 border-2 border-theme-border border-t-theme-muted rounded-full animate-spin"></div></div>`;
  const SPINNER_SM = `<div class="loader-spinner inline-block h-4 w-4 border-2 border-theme-border border-t-theme-muted rounded-full animate-spin align-middle"></div>`;

  // ============================================================
  // SVG ICONS (Feather-style stroke icons + Bluesky butterfly)
  // ============================================================
  const ICON = {
    heart: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`,
    heartFill: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`,
    repost: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 2 21 6 17 10"></polyline><path d="M3 11v-1a4 4 0 0 1 4-4h14"></path><polyline points="7 22 3 18 7 14"></polyline><path d="M21 13v1a4 4 0 0 1-4 4H3"></path></svg>`,
    reply: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>`,
    share: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>`,
    squad: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
