      if (myHandle) {
        const profileRes = await fetchTimeout(`https://public.api.bsky.app/xrpc/app.bsky.actor.getProfile?actor=${encodeURIComponent(myHandle)}`, {}, 8000);
        if (profileRes.ok) { const profile = await profileRes.json(); myAvatar = profile.avatar || null; myDisplayName = profile.displayName || myHandle; }
