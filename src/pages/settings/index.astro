---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../lib/config';
import labels from '../../content/labels.json';
const bl = labels.bluesky;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Settings">
  <div class="mx-auto max-w-xl">
    <h1 class="text-2xl font-bold mb-8">{labels.settings.heading}</h1>

    <div id="auth-required" class="hidden text-center py-12 text-theme-faint">
      <p>{labels.settings.signInPrompt}</p>
      <a href={`${base}/social/`} class="mt-4 inline-block rounded bg-theme-primary text-white px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">
        {labels.settings.signInButton}
      </a>
    </div>

    <div id="settings-content" class="hidden space-y-6">
      <!-- Bluesky Connection -->
      <div id="status-card" class="rounded-lg border border-theme-card-border bg-theme-card p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold">{bl.connectionStatus}</h2>
          <span id="status-badge" class="text-xs px-2 py-1 rounded-full"></span>
        </div>
        <div id="status-details" class="text-sm text-theme-muted"></div>
      </div>

      <div id="connect-form" class="hidden rounded-lg border border-theme-card-border bg-theme-card p-6">
        <h2 class="text-lg font-semibold mb-4">{bl.connectHeading}</h2>
        <p class="text-sm text-theme-muted mb-4">
          Use an <a href="https://bsky.app/settings/app-passwords" target="_blank" class="text-theme-primary hover:underline">App Password</a> — never your main password.
        </p>
        <form id="bsky-connect-form" class="space-y-4">
          <div>
            <label for="bsky-handle" class="block text-sm font-medium mb-1">{bl.handleLabel}</label>
            <input type="text" id="bsky-handle" placeholder="yourname.bsky.social"
              class="w-full rounded bg-theme-input-bg border border-theme-input-border px-3 py-2 text-sm focus:outline-none focus:border-theme-primary" />
          </div>
          <div>
            <label for="bsky-password" class="block text-sm font-medium mb-1">{bl.passwordLabel}</label>
            <input type="password" id="bsky-password" placeholder="xxxx-xxxx-xxxx-xxxx"
              class="w-full rounded bg-theme-input-bg border border-theme-input-border px-3 py-2 text-sm focus:outline-none focus:border-theme-primary" />
          </div>
          <div id="connect-error" class="hidden text-red-400 text-sm"></div>
          <button type="submit" class="w-full rounded bg-theme-primary px-4 py-2 text-sm font-medium text-white hover:bg-theme-primary-hover transition">
            {bl.connectButton}
          </button>
        </form>
      </div>

      <div id="connected-actions" class="hidden space-y-4">
        <div class="flex gap-3">
          <button id="toggle-btn" class="flex-1 rounded px-4 py-2 text-sm font-medium transition"></button>
          <button id="disconnect-btn" class="rounded bg-red-900 px-4 py-2 text-sm font-medium hover:bg-red-800 transition">
            Disconnect
          </button>
        </div>
      </div>

      <!-- Social Display Settings -->
      <div class="rounded-lg border border-theme-card-border bg-theme-card p-6">
        <h2 class="text-lg font-semibold mb-4">Social Display</h2>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <div>
              <div class="text-sm font-medium">Highlight Squad Posts</div>
              <div class="text-xs text-theme-muted">Show a badge and colored border on posts from squad members</div>
              <div class="text-xs text-theme-faint mt-1">Set colors per squad in the Squads tab on Social</div>
            </div>
            <button id="squad-highlight-toggle" class="relative w-10 h-5 rounded-full transition-colors" style="background:var(--ps-input-border,#444)">
              <span class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full bg-white transition-all"></span>
            </button>
          </div>
          <div class="flex items-center justify-between pt-4 border-t border-theme-card-border">
            <div>
              <div class="text-sm font-medium">Video Mini-Player</div>
              <div class="text-xs text-theme-muted">Float playing videos when scrolled out of view</div>
            </div>
            <button id="miniplayer-toggle" class="relative w-10 h-5 rounded-full transition-colors" style="background:var(--ps-input-border,#444)">
              <span class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full bg-white transition-all"></span>
            </button>
          </div>
          <button id="reset-miniplayer-pos" class="text-xs text-theme-faint hover:text-theme-text transition">Reset mini-player position</button>
        </div>
      </div>

      <!-- Notification Settings -->
      <div class="rounded-lg border border-theme-card-border bg-theme-card p-6">
        <h2 class="text-lg font-semibold mb-4">Notification Settings</h2>
        <div id="notif-settings-loading" class="flex justify-center py-4">
          <div class="animate-spin rounded-full h-6 w-6 border-2 border-theme-primary border-t-transparent"></div>
        </div>
        <div id="notif-settings-actions" class="hidden space-y-2 mb-4">
          <button id="enable-push-btn" class="w-full rounded bg-theme-input-bg border border-theme-border px-4 py-2 text-sm hover:bg-theme-surface-hover transition">Enable Push Notifications</button>
          <button id="test-push-btn" class="hidden w-full rounded bg-theme-primary px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">Send Test Notification</button>
        </div>
        <div id="notif-settings-body" class="hidden space-y-0">
          <details class="group">
            <summary class="flex items-center justify-between cursor-pointer py-2 mb-1">
              <h3 class="text-xs font-semibold text-theme-faint uppercase tracking-wider">Push Notifications</h3>
              <span class="text-theme-faint text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="pb-2">
              <label class="flex items-center justify-between py-3 border-b border-theme-border cursor-pointer">
                <div><span class="text-sm font-medium">Push Notifications</span><p class="text-xs text-theme-faint mt-0.5">Receive desktop/mobile push alerts</p></div>
                <input type="checkbox" id="pref-push" class="notif-pref-toggle w-5 h-5 accent-[var(--ps-primary)]" />
              </label>
              <label class="flex items-center justify-between py-3 border-b border-theme-border cursor-pointer">
                <div><span class="text-sm font-medium">Notification Sound</span><p class="text-xs text-theme-faint mt-0.5">Play a sound for new notifications</p></div>
                <input type="checkbox" id="pref-sound" class="notif-pref-toggle w-5 h-5 accent-[var(--ps-primary)]" />
              </label>
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between cursor-pointer py-2 mb-1">
              <h3 class="text-xs font-semibold text-theme-faint uppercase tracking-wider">Nudges</h3>
              <span class="text-theme-faint text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="pb-2">
              <label class="flex items-center justify-between py-3 border-b border-theme-border cursor-pointer">
                <div><span class="text-sm font-medium">Allow Nudges</span><p class="text-xs text-theme-faint mt-0.5">Let other pirates nudge you</p></div>
                <input type="checkbox" id="pref-nudges" class="notif-pref-toggle w-5 h-5 accent-[var(--ps-primary)]" />
              </label>
              <label class="flex items-center justify-between py-3 border-b border-theme-border cursor-pointer">
                <div><span class="text-sm font-medium">Nudge Sound</span><p class="text-xs text-theme-faint mt-0.5">Play a sound when nudged</p></div>
                <input type="checkbox" id="pref-nudge-sound" class="notif-pref-toggle w-5 h-5 accent-[var(--ps-primary)]" />
              </label>
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between cursor-pointer py-2 mb-1">
              <h3 class="text-xs font-semibold text-theme-faint uppercase tracking-wider">Notify me about</h3>
              <span class="text-theme-faint text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="pb-2">
              <label class="flex items-center justify-between py-3 border-b border-theme-border cursor-pointer">
                <div><span class="text-sm font-medium">Likes</span></div>
                <input type="checkbox" id="pref-likes" class="notif-pref-toggle w-5 h-5 accent-[var(--ps-primary)]" />
              </label>
              <label class="flex items-center justify-between py-3 border-b border-theme-border cursor-pointer">
                <div><span class="text-sm font-medium">Replies</span></div>
                <input type="checkbox" id="pref-comments" class="notif-pref-toggle w-5 h-5 accent-[var(--ps-primary)]" />
              </label>
              <label class="flex items-center justify-between py-3 border-b border-theme-border cursor-pointer">
                <div><span class="text-sm font-medium">Reposts</span></div>
                <input type="checkbox" id="pref-reposts" class="notif-pref-toggle w-5 h-5 accent-[var(--ps-primary)]" />
              </label>
              <label class="flex items-center justify-between py-3 border-b border-theme-border cursor-pointer">
                <div><span class="text-sm font-medium">New Followers</span></div>
                <input type="checkbox" id="pref-follows" class="notif-pref-toggle w-5 h-5 accent-[var(--ps-primary)]" />
              </label>
              <label class="flex items-center justify-between py-3 border-b border-theme-border cursor-pointer">
                <div><span class="text-sm font-medium">Mentions</span></div>
                <input type="checkbox" id="pref-mentions" class="notif-pref-toggle w-5 h-5 accent-[var(--ps-primary)]" />
              </label>
            </div>
          </details>
        </div>
        <div id="notif-settings-error" class="hidden text-center py-4 text-red-400 text-sm">Failed to load notification settings</div>
      </div>

      <!-- Site URL Settings -->
      <div class="rounded-lg border border-theme-card-border bg-theme-card p-6">
        <h2 class="text-lg font-semibold mb-4">Site URL</h2>
        <p class="text-xs text-theme-muted mb-3">Your site's custom domain. This controls where you're redirected after login and how other pirates find your site.</p>
        <div class="flex gap-2">
          <input type="url" id="site-url-input" placeholder="https://yourdomain.com"
            class="flex-1 rounded bg-theme-input-bg border border-theme-input-border px-3 py-2 text-sm focus:outline-none focus:border-theme-primary" />
          <button id="site-url-save" class="rounded bg-theme-primary px-3 py-2 text-sm font-medium text-white hover:bg-theme-primary-hover transition">Save</button>
        </div>
        <div id="site-url-msg" class="hidden text-sm mt-2"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ hubUrl: siteConfig.hubUrl, BL: labels.bluesky }} data-astro-rerun>
  const token = localStorage.getItem(`ps_token:${window.__PS_BASE || '/'}`);

  const defaultSocialSettings = { squadHighlight: true, squadBorderColor: '#eab308', miniPlayerEnabled: true, miniPlayerX: null, miniPlayerY: null };
  let socialSettings = { ...defaultSocialSettings };
  try { const s = JSON.parse(localStorage.getItem('ps_social_settings')); if (s) socialSettings = { ...defaultSocialSettings, ...s }; } catch {}
  function saveSocialSettings() { localStorage.setItem('ps_social_settings', JSON.stringify(socialSettings)); }

  function initSocialSettings() {
    const highlightToggle = document.getElementById('squad-highlight-toggle');
    const miniToggle = document.getElementById('miniplayer-toggle');
    const resetPos = document.getElementById('reset-miniplayer-pos');

    function updateToggle(btn, on) {
      btn.style.background = on ? 'var(--ps-accent,#3b82f6)' : 'var(--ps-input-border,#444)';
      const dot = btn.querySelector('span');
      dot.style.left = on ? '' : '2px';
      dot.style.right = on ? '2px' : '';
    }

    updateToggle(highlightToggle, socialSettings.squadHighlight);
    updateToggle(miniToggle, socialSettings.miniPlayerEnabled);

    highlightToggle.addEventListener('click', () => {
      socialSettings.squadHighlight = !socialSettings.squadHighlight;
      updateToggle(highlightToggle, socialSettings.squadHighlight);
      saveSocialSettings();
    });

    miniToggle.addEventListener('click', () => {
      socialSettings.miniPlayerEnabled = !socialSettings.miniPlayerEnabled;
      updateToggle(miniToggle, socialSettings.miniPlayerEnabled);
      saveSocialSettings();
    });

    resetPos.addEventListener('click', () => {
      socialSettings.miniPlayerX = null;
      socialSettings.miniPlayerY = null;
      saveSocialSettings();
      resetPos.textContent = 'Position reset ✓';
      setTimeout(() => { resetPos.textContent = 'Reset mini-player position'; }, 1500);
    });
  }

  if (!token) {
    document.getElementById('auth-required').classList.remove('hidden');
  } else {
    document.getElementById('settings-content').classList.remove('hidden');
    loadStatus();
    initSocialSettings();
    loadSiteUrl();
    loadNotifSettings();
  }

  // Site URL management
  async function loadSiteUrl() {
    try {
      const res = await fetch(`${hubUrl}/api/auth/me`, { headers: { Authorization: `Bearer ${token}` } });
      if (res.ok) {
        const data = await res.json();
        document.getElementById('site-url-input').value = data.siteUrl || '';
      }
    } catch {}
  }

  document.getElementById('site-url-save')?.addEventListener('click', async () => {
    const input = document.getElementById('site-url-input');
    const msg = document.getElementById('site-url-msg');
    const url = input.value.trim();
    if (!url || !url.startsWith('https://')) {
      msg.textContent = 'URL must start with https://';
      msg.className = 'text-red-400 text-sm mt-2';
      msg.classList.remove('hidden');
      return;
    }
    try {
      const feedUrl = url.replace(/\/$/, '') + '/feed.xml';
      const res = await fetch(`${hubUrl}/api/users/me`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({ siteUrl: url.replace(/\/$/, ''), feedUrl }),
      });
      if (res.ok) {
        msg.textContent = 'Site URL updated! Login will now redirect here.';
        msg.className = 'text-green-400 text-sm mt-2';
      } else {
        msg.textContent = 'Failed to update';
        msg.className = 'text-red-400 text-sm mt-2';
      }
      msg.classList.remove('hidden');
      setTimeout(() => msg.classList.add('hidden'), 4000);
    } catch {
      msg.textContent = 'Network error';
      msg.className = 'text-red-400 text-sm mt-2';
      msg.classList.remove('hidden');
    }
  });

  async function loadStatus() {
    try {
      const res = await fetch(`${hubUrl}/api/bluesky/status`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      const data = await res.json();
      renderStatus(data);
    } catch (err) {
      console.error('Failed to load Bluesky status:', err);
      renderStatus({ connected: false });
    }
  }

  function renderStatus(data) {
    const badge = document.getElementById('status-badge');
    const details = document.getElementById('status-details');
    const connectForm = document.getElementById('connect-form');
    const connectedActions = document.getElementById('connected-actions');
    const toggleBtn = document.getElementById('toggle-btn');

    if (data.connected) {
      badge.textContent = data.enabled ? BL.active : BL.paused;
      badge.className = `text-xs px-2 py-1 rounded-full ${data.enabled ? 'bg-green-900 text-green-300' : 'bg-yellow-900 text-yellow-300'}`;
      details.innerHTML = `
        <p><strong>Handle:</strong> @${data.handle}</p>
        <p class="mt-1"><strong>DID:</strong> <code class="text-xs">${data.did}</code></p>
        <p class="mt-1"><strong>Cross-posting:</strong> ${data.enabled ? 'New posts will appear on Bluesky' : 'Paused — new posts will not be cross-posted'}</p>
      `;
      connectForm.classList.add('hidden');
      connectedActions.classList.remove('hidden');
      toggleBtn.textContent = data.enabled ? BL.pauseCrosspost : BL.enableCrosspost;
      toggleBtn.className = `flex-1 rounded px-4 py-2 text-sm font-medium transition ${data.enabled ? 'bg-yellow-700 hover:bg-yellow-600' : 'bg-green-700 hover:bg-green-600'}`;
    } else {
      badge.textContent = BL.notConnected;
      badge.className = 'text-xs px-2 py-1 rounded-full bg-theme-surface-hover text-theme-text';
      details.innerHTML = `<p>${BL.noAccount}</p>`;
      connectForm.classList.remove('hidden');
      connectedActions.classList.add('hidden');
    }
  }

  document.getElementById('bsky-connect-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const handle = document.getElementById('bsky-handle').value.trim();
    const appPassword = document.getElementById('bsky-password').value.trim();
    const errorEl = document.getElementById('connect-error');
    errorEl.classList.add('hidden');

    if (!handle || !appPassword) {
      errorEl.textContent = 'Both fields are required';
      errorEl.classList.remove('hidden');
      return;
    }

    try {
      const res = await fetch(`${hubUrl}/api/bluesky/connect`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({ handle, appPassword }),
      });
      const data = await res.json();
      if (!res.ok) { errorEl.textContent = data.error || 'Connection failed'; errorEl.classList.remove('hidden'); return; }
      loadStatus();
    } catch { errorEl.textContent = 'Network error'; errorEl.classList.remove('hidden'); }
  });

  document.getElementById('toggle-btn').addEventListener('click', async () => {
    await fetch(`${hubUrl}/api/bluesky/toggle`, { method: 'POST', headers: { Authorization: `Bearer ${token}` } });
    loadStatus();
  });

  document.getElementById('disconnect-btn').addEventListener('click', async () => {
    if (!confirm('Disconnect your Bluesky account? Existing cross-posts will remain on Bluesky.')) return;
    await fetch(`${hubUrl}/api/bluesky/disconnect`, { method: 'POST', headers: { Authorization: `Bearer ${token}` } });
    loadStatus();
  });

  // Notification Settings
  function urlBase64ToUint8Array(base64String) {
    const padding = '='.repeat((4 - base64String.length % 4) % 4);
    const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
    const rawData = atob(base64);
    const outputArray = new Uint8Array(rawData.length);
    for (let i = 0; i < rawData.length; ++i) outputArray[i] = rawData.charCodeAt(i);
    return outputArray;
  }

  async function loadNotifSettings() {
    const loading = document.getElementById('notif-settings-loading');
    const body = document.getElementById('notif-settings-body');
    const actions = document.getElementById('notif-settings-actions');
    const errorEl = document.getElementById('notif-settings-error');

    try {
      const res = await fetch(`${hubUrl}/api/notifications/preferences`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      const prefs = await res.json();

      // Set toggle states
      const keyMap = {
        'pref-push': 'pushEnabled', 'pref-sound': 'soundEnabled',
        'pref-nudges': 'nudgesEnabled', 'pref-nudge-sound': 'nudgeSoundEnabled',
        'pref-likes': 'likes', 'pref-comments': 'comments',
        'pref-reposts': 'reposts', 'pref-follows': 'follows', 'pref-mentions': 'mentions',
      };
      Object.entries(keyMap).forEach(([id, key]) => {
        const el = document.getElementById(id);
        if (el) el.checked = !!prefs[key];
      });

      // Show test push button if push enabled
      if (prefs.pushEnabled) {
        document.getElementById('test-push-btn').classList.remove('hidden');
      }

      // Update enable push button text
      const enableBtn = document.getElementById('enable-push-btn');
      if (typeof Notification !== 'undefined' && Notification.permission === 'granted') {
        enableBtn.textContent = '✓ Push Enabled';
      }

      loading.classList.add('hidden');
      body.classList.remove('hidden');
      actions.classList.remove('hidden');

      // Save on toggle change
      body.querySelectorAll('.notif-pref-toggle').forEach(input => {
        input.addEventListener('change', async () => {
          const key = keyMap[input.id];
          if (!key) return;
          try {
            await fetch(`${hubUrl}/api/notifications/preferences`, {
              method: 'PUT',
              headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
              body: JSON.stringify({ [key]: input.checked }),
            });
            // Show/hide test push button based on push toggle
            if (key === 'pushEnabled') {
              document.getElementById('test-push-btn').classList.toggle('hidden', !input.checked);
            }
          } catch {}
        });
      });

      // Test push button
      document.getElementById('test-push-btn').addEventListener('click', async () => {
        try {
          await fetch(`${hubUrl}/api/notifications/push/test`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          });
        } catch {}
      });

      // Enable push button
      document.getElementById('enable-push-btn').addEventListener('click', async () => {
        try {
          const permission = await Notification.requestPermission();
          if (permission !== 'granted') return;

          const vapidRes = await fetch(`${hubUrl}/api/notifications/vapid-key`);
          const { publicKey } = await vapidRes.json();
          if (!publicKey) return;

          const reg = await navigator.serviceWorker.ready;
          const sub = await reg.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: urlBase64ToUint8Array(publicKey),
          });

          const subJson = sub.toJSON();
          await fetch(`${hubUrl}/api/notifications/push/subscribe`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ endpoint: subJson.endpoint, keys: subJson.keys }),
          });

          document.getElementById('enable-push-btn').textContent = '✓ Push Enabled';
        } catch (err) {
          console.error('[PS] Push setup error:', err);
        }
      });
    } catch {
      loading.classList.add('hidden');
      errorEl.classList.remove('hidden');
    }
  }
</script>
