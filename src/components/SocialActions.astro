---
import { siteConfig } from '../lib/config';
import labels from '../content/labels.json';

interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<div class="mt-8 border-t border-theme-border pt-6" id={`social-${postSlug}`}>
  <div class="flex items-center gap-4 text-sm text-theme-muted">
    <button class="like-action hover:text-red-400 transition cursor-pointer" data-slug={postSlug}>
      ♡ <span class="like-count">0</span>
    </button>
    <button class="comment-toggle hover:text-blue-400 transition cursor-pointer" data-slug={postSlug}>
      💬 <span class="comment-count">0</span> {labels.components.comments}
    </button>
    <button class="post-share-btn hover:text-green-400 transition cursor-pointer" data-slug={postSlug}>
      {labels.components.share}
    </button>
    <a class="bsky-link hidden text-blue-400 hover:text-blue-300 transition text-xs" data-slug={postSlug} href="#" target="_blank" rel="noopener">
      {labels.components.viewOnBluesky}
    </a>
  </div>

  <!-- Bluesky stats -->
  <div class="bsky-stats hidden mt-2 text-xs text-theme-faint" data-slug={postSlug}>
    <span class="bsky-likes"></span>
    <span class="bsky-reposts ml-2"></span>
  </div>

  <!-- Comments section (hidden by default) -->
  <div class="comments-section hidden mt-4" data-slug={postSlug}>
    <div class="comments-list space-y-3 mb-4"></div>
    <div class="flex gap-2">
      <input
        type="text"
        class="comment-input flex-1 rounded bg-theme-input-bg border border-theme-input-border px-3 py-2 text-sm text-theme-text placeholder-theme-faint focus:outline-none focus:border-theme-primary"
        placeholder={labels.components.commentPlaceholder}
        maxlength="2000"
      />
      <button class="comment-submit rounded bg-theme-surface-hover px-4 py-2 text-sm hover:bg-theme-card-hover transition cursor-pointer">
        {labels.components.postButton}
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ hubUrl: siteConfig.hubUrl }}>
(function() {
  const postStates = {};

  function getToken() {
    return localStorage.getItem(`ps_token:${window.__PS_BASE || '/'}`);
  }

  // Resolve slug to postId + bluesky data via hub
  async function resolvePost(slug) {
    if (postStates[slug]) return postStates[slug];
    try {
      // Construct a guid that matches what the aggregator stores
      // The guid is typically the full URL: siteUrl + /posts/ + slug
      const guids = [
        slug,
        `${window.location.origin}/posts/${slug}/`,
        `${window.location.origin}/posts/${slug}`,
      ];

      let data = null;
      for (const guid of guids) {
        const res = await fetch(`${hubUrl}/api/feed/by-guid/${encodeURIComponent(guid)}`);
        if (res.ok) {
          data = await res.json();
          break;
        }
      }

      if (data) {
        postStates[slug] = data;
        return data;
      }
    } catch (e) {
      console.warn('Could not resolve post:', e);
    }
    return null;
  }

  // Load merged comments (Pirate Social + Bluesky)
  async function loadComments(slug) {
    const post = await resolvePost(slug);
    if (!post) return;

    try {
      const res = await fetch(`${hubUrl}/api/bluesky/thread/${post.id}`);
      if (!res.ok) return;
      const data = await res.json();

      // Update counts
      const container = document.getElementById(`social-${slug}`);
      if (!container) return;

      const commentCount = container.querySelector('.comment-count');
      commentCount.textContent = data.comments.length;

      const likeCount = container.querySelector('.like-count');
      likeCount.textContent = data.likeCount + (data.bskyLikeCount || 0);

      // Show Bluesky link if available
      if (data.bskyUrl) {
        const bskyLink = container.querySelector('.bsky-link');
        bskyLink.href = data.bskyUrl;
        bskyLink.classList.remove('hidden');
      }

      // Show Bluesky stats
      if (data.bskyLikeCount > 0 || data.bskyRepostCount > 0) {
        const stats = container.querySelector('.bsky-stats');
        stats.classList.remove('hidden');
        stats.querySelector('.bsky-likes').textContent = data.bskyLikeCount > 0 ? `🦋 ${data.bskyLikeCount} likes` : '';
        stats.querySelector('.bsky-reposts').textContent = data.bskyRepostCount > 0 ? `🔁 ${data.bskyRepostCount} reposts` : '';
      }

      // Render comments
      const list = container.querySelector('.comments-list');
      list.innerHTML = '';

      if (data.comments.length === 0) {
        list.innerHTML = '<p class="text-sm text-theme-faint italic">No comments yet</p>';
        return;
      }

      data.comments.forEach(c => {
        const div = document.createElement('div');
        div.className = 'flex gap-3 text-sm';
        if (c.depth > 0) div.style.marginLeft = `${c.depth * 1.5}rem`;

        const sourceIcon = c.source === 'bluesky' ? '🦋' : '🏴‍☠️';
        const avatar = c.author.avatar
          ? `<img src="${c.author.avatar}" alt="" class="w-6 h-6 rounded-full flex-shrink-0" />`
          : `<div class="w-6 h-6 rounded-full bg-theme-surface-hover flex-shrink-0"></div>`;

        const time = new Date(c.createdAt).toLocaleDateString('en-US', {
          month: 'short', day: 'numeric',
        });

        div.innerHTML = `
          ${avatar}
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="font-medium text-theme-text">${escapeHtml(c.author.displayName || c.author.handle)}</span>
              <span class="text-theme-faint text-xs">${sourceIcon}</span>
              <span class="text-theme-faint text-xs">${time}</span>
            </div>
            <p class="text-theme-muted mt-0.5 break-words">${escapeHtml(c.text)}</p>
          </div>
        `;
        list.appendChild(div);
      });

      // Store blueskyUri for like bridge
      post.blueskyUri = data.blueskyUri;
    } catch (e) {
      console.warn('Failed to load comments:', e);
    }
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str || '';
    return div.innerHTML;
  }

  // Toggle comments
  document.querySelectorAll('.comment-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug;
      const section = document.querySelector(`.comments-section[data-slug="${slug}"]`);
      const wasHidden = section.classList.contains('hidden');
      section.classList.toggle('hidden');
      if (wasHidden) loadComments(slug);
    });
  });

  // Like action
  document.querySelectorAll('.like-action').forEach(btn => {
    btn.addEventListener('click', async () => {
      const token = getToken();
      if (!token) return alert('Sign in to like posts');

      const slug = btn.dataset.slug;
      const post = await resolvePost(slug);
      if (!post) return alert('Post not found in hub');

      try {
        const res = await fetch(`${hubUrl}/api/interactions/like`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ postId: post.id }),
        });

        if (res.status === 409) {
          // Already liked — unlike
          const ures = await fetch(`${hubUrl}/api/interactions/like`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
            body: JSON.stringify({ postId: post.id }),
          });
          if (ures.ok) {
            const data = await ures.json();
            btn.querySelector('.like-count').textContent = data.count;
            btn.innerHTML = `♡ <span class="like-count">${data.count}</span>`;
          }
          return;
        }

        if (res.ok) {
          const data = await res.json();
          btn.innerHTML = `♥ <span class="like-count">${data.count}</span>`;
          btn.classList.add('text-red-400');

          // Bridge like to Bluesky
          fetch(`${hubUrl}/api/bluesky/like-bridge/${post.id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          }).catch(() => {});
        }
      } catch (e) {
        console.warn('Like failed:', e);
      }
    });
  });

  // Comment submit
  document.querySelectorAll('.comment-submit').forEach(btn => {
    btn.addEventListener('click', async () => {
      const token = getToken();
      if (!token) return alert('Sign in to comment');

      const input = btn.previousElementSibling;
      const body = input.value.trim();
      if (!body) return;

      const slug = input.closest('.comments-section').dataset.slug;
      const post = await resolvePost(slug);
      if (!post) return alert('Post not found in hub');

      try {
        // Post comment to Pirate Social
        const res = await fetch(`${hubUrl}/api/interactions/comment`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ postId: post.id, body }),
        });

        if (res.ok) {
          input.value = '';

          // Also bridge to Bluesky if post is cross-posted
          if (post.blueskyUri) {
            fetch(`${hubUrl}/api/bluesky/reply/${post.id}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
              body: JSON.stringify({ text: body }),
            }).catch(() => {});
          }

          // Refresh comments
          loadComments(slug);
        }
      } catch (e) {
        console.warn('Comment failed:', e);
      }
    });
  });

  // --- Share modal ---
  if (!document.getElementById('share-modal-overlay')) {
    const shareOverlay = document.createElement('div');
    shareOverlay.id = 'share-modal-overlay';
    shareOverlay.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:50;justify-content:center;align-items:center';
    shareOverlay.innerHTML = `
      <div id="share-modal" style="background:var(--ps-card-bg);border:1px solid var(--ps-card-border);border-radius:.75rem;padding:1.5rem;width:20rem;max-width:90vw">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
          <h3 style="font-weight:600;font-size:1rem">Share</h3>
          <button id="share-close" style="color:var(--ps-text-muted);font-size:1.25rem;cursor:pointer;background:none;border:none">✕</button>
        </div>
        <div id="share-links" style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem"></div>
      </div>`;
    document.body.appendChild(shareOverlay);
    shareOverlay.addEventListener('click', (e) => { if (e.target === shareOverlay) shareOverlay.style.display = 'none'; });
    document.getElementById('share-close').addEventListener('click', () => document.getElementById('share-modal-overlay').style.display = 'none');
  }

  function openPostShareModal(url, title) {
    const overlay = document.getElementById('share-modal-overlay');
    const enc = encodeURIComponent;
    const links = [
      { label: '𝕏 Twitter', href: `https://twitter.com/intent/tweet?text=${enc(title)}&url=${enc(url)}` },
      { label: '📘 Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}` },
      { label: '💼 LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}` },
      { label: '📌 Pinterest', href: `https://pinterest.com/pin/create/button/?url=${enc(url)}&description=${enc(title)}` },
      { label: '🔗 Reddit', href: `https://www.reddit.com/submit?url=${enc(url)}&title=${enc(title)}` },
      { label: '📧 Email', href: `mailto:?subject=${enc(title)}&body=${enc(url)}` },
    ];
    const linksHtml = links.map(l =>
      `<a href="${l.href}" target="_blank" rel="noopener noreferrer" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:var(--ps-input-bg);color:var(--ps-text);font-size:.875rem;text-decoration:none;transition:background .15s" onmouseover="this.style.background='var(--ps-surface-hover)'" onmouseout="this.style.background='var(--ps-input-bg)'">${l.label}</a>`
    ).join('');
    const copyBtn = `<button id="share-copy" style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:.5rem;background:var(--ps-input-bg);color:var(--ps-text);font-size:.875rem;border:none;cursor:pointer;transition:background .15s;grid-column:span 2" onmouseover="this.style.background='var(--ps-surface-hover)'" onmouseout="this.style.background='var(--ps-input-bg)'">📋 Copy Link</button>`;
    document.getElementById('share-links').innerHTML = linksHtml + copyBtn;
    document.getElementById('share-copy').addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(url);
        document.getElementById('share-copy').textContent = '✓ Copied!';
        setTimeout(() => document.getElementById('share-copy').textContent = '📋 Copy Link', 2000);
      } catch {}
    });
    overlay.style.display = 'flex';
  }

  document.querySelectorAll('.post-share-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const url = window.location.href;
      const title = document.querySelector('h1')?.textContent || document.title;
      openPostShareModal(url, title);
    });
  });

  // Auto-load comment counts on page load
  document.querySelectorAll('.like-action').forEach(btn => {
    const slug = btn.dataset.slug;
    resolvePost(slug).then(post => {
      if (post) {
        btn.querySelector('.like-count').textContent = post._count?.likes || 0;
      }
    });
  });
})();
</script>
