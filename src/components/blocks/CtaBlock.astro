---
import CtaLinks from './CtaLinks.astro';

const { heading, description, links = [], align = 'center', layout = 'narrow' } = Astro.props;

const widthClass = layout === 'full' ? 'w-full' : 'max-w-3xl mx-auto';
const textAlign: Record<string, string> = { left: 'text-left', center: 'text-center', right: 'text-right' };
---

<section class={`mb-12 px-4 ${widthClass}`}>
  <div class={textAlign[align] || 'text-center'}>
    {heading && (
      <h2 class="text-2xl md:text-3xl font-bold font-heading mb-3">{heading}</h2>
    )}
    {description && (
      <p class="text-theme-muted mb-6 max-w-xl mx-auto">{description}</p>
    )}
    <CtaLinks links={links} align={align} />
  </div>
</section>
